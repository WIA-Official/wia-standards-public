{
  "name": "@wia/plastic-enzyme-sdk",
  "version": "1.0.0",
  "description": "WIA-PLASTIC-ENZYME Standard SDK for enzymatic plastic degradation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git"
  },
  "homepage": "https://wiastandards.com/plastic-enzyme",
  "author": "WIA - World Certification Industry Association",
  "license": "MIT",
  "keywords": [
    "wia",
