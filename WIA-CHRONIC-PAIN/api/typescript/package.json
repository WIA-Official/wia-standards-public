{
  "name": "@wia/chronic-pain-sdk",
  "version": "1.0.0",
  "description": "WIA-CHRONIC-PAIN SDK - Neuroplasticity Reversal Chronic Pain Standard",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wia",
    "chronic-pain",
    "neuroplasticity",
    "central-sensitization",
    "neuromodulation",
    "tms",
    "tdcs",
    "pain-management",
    "cbt",
    "opioid-reduction"
  ],
  "author": "WIA (World Certification Industry Association)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/WIA-CHRONIC-PAIN/api/typescript"
  },
  "homepage": "https://wia.live/chronic-pain",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  }
}
