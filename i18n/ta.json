  "little_prince": {
    "q1": "நட்சத்திரங்களைப் பார்க்கும் போது, உன் நட்சத்திரத்தில் சிரிக்கிற நீயே நினைவுக்கு வருகிறாய், அதனால் எல்லா நட்சத்திரங்களும் சிரிக்கிறதுபோல இருக்கிறது.",
    "q2": "முதிர்வோர்கள் எண்களை விரும்புகிறார்கள். புதிய நண்பர்கள் பற்றிய கதைகள் பேசும் போது, அடிப்படையானதை கேட்கவில்லை.",
    "q3": "மலைப்பாதை அழகானது, ஏனெனில் எங்கு ஒரு கிணறு மறைக்கப்பட்டுள்ளது.",
    "q4": "மிகவும் முக்கியமானது கண்களுக்கு தெரியாதது.",
    "q5": "நீ உன் ரோஜாவிற்காக இழந்த நேரம், அந்த நேரம் உன் ரோஜாவை மதிப்புமிக்கதாக மாற்றியது.",
    "q6": "நட்சத்திரங்கள் ஒவ்வொருவருக்கும் வேறு அர்த்தம் கொண்டது. பயணிக்கும் ஒருவருக்கு அது வழிகாட்டியாக இருக்கிறது.",
    "q7": "அழகானது என்பது உறவுகளை உருவாக்குவதாகும்.",
    "q8": "முதிர்வோராக இருக்கும்போது, குழந்தையாக இருந்தது நினைவில் வைத்திருப்பவர்கள் மிகவும் குறைவாக உள்ளனர்.",
    "q9": "மட்டுமட்டும் குழந்தைகள் தாங்கள் என்ன தேடுகிறார்கள் என்பதை அறிவார்கள்.",
    "q10": "மக்கள் உண்மையை தேடுவதற்கு மிகவும் பிஸியாக வாழ்கிறார்கள்."
  },
