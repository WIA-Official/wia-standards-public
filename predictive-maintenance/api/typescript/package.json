{
  "name": "@wia/ind-026",
  "version": "1.0.0",
  "description": "WIA-IND-026: Predictive Maintenance SDK - Comprehensive predictive maintenance solution with multi-modal sensor analysis and ML-powered failure prediction",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "docs": "typedoc src/index.ts"
  },
  "keywords": [
    "wia",
    "predictive-maintenance",
    "condition-monitoring",
    "vibration-analysis",
    "thermal-imaging",
    "oil-analysis",
    "acoustic-monitoring",
    "machine-learning",
    "failure-prediction",
    "rul",
    "remaining-useful-life",
    "industry-4.0",
    "iot",
    "sensor-data",
    "maintenance-optimization"
  ],
  "author": "WIA (World Certification Industry Association)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/predictive-maintenance"
  },
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "homepage": "https://github.com/WIA-Official/wia-standards/tree/main/standards/predictive-maintenance#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "eventemitter3": "^5.0.1",
    "ws": "^8.16.0",
    "fft.js": "^4.0.4",
    "ml-matrix": "^6.10.4",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
