{
  "name": "@wia/mental-wellness",
  "version": "1.0.0",
  "description": "WIA Mental Wellness Standard - TypeScript SDK for digital mental health platforms, therapy apps, and wellness tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "wia",
    "mental-wellness",
    "mental-health",
    "therapy",
    "teletherapy",
    "mood-tracking",
    "CBT",
    "DBT",
    "mindfulness",
    "meditation",
    "crisis-intervention",
    "depression",
    "anxiety",
    "assessment",
    "PHQ-9",
    "GAD-7",
    "wellness",
    "healthcare"
  ],
  "author": "WIA (World Industry Association)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/WIA-MENTAL_WELLNESS/api/typescript"
  },
  "homepage": "https://standards.wia.org/mental-wellness",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
