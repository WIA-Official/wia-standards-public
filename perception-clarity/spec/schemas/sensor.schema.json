{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiastandards.com/perception-clarity/spec/schemas/sensor.schema.json",
  "title": "Sensor Clarity",
  "description": "Perception clarity status for a single sensor.",
  "type": "object",
  "properties": {
    "sensorId": { "type": "string", "description": "Stable identifier for the sensor within the agent." },
    "sensorClass": {
      "type": "string",
      "enum": ["rgb_camera", "ir_thermal", "lidar_window", "radar_radome", "ultrasonic"]
    },
    "pci": { "type": "integer", "minimum": 0, "maximum": 100 },
    "state": {
      "type": "string",
      "enum": ["clear", "degraded", "obstructed", "blind"]
    },
    "contaminants": {
      "type": "array",
      "items": { "$ref": "contaminant.schema.json" },
      "default": []
    },
    "axes": {
      "type": "object",
      "properties": {
        "occlusion": { "type": "number", "minimum": 0, "maximum": 1 },
        "distanceDegradation": { "type": "number", "minimum": 0, "maximum": 1 },
        "mtfReduction": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "pciWeights": {
      "type": "object",
      "properties": {
        "occlusion": { "type": "number", "minimum": 0, "maximum": 1 },
        "distance": { "type": "number", "minimum": 0, "maximum": 1 },
        "mtf": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "lastCleanedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp of last successful cleaning/restoration, or null if never."
    },
    "dwellSeconds": {
      "type": "number",
      "minimum": 0,
      "description": "Seconds the sensor has continuously been in a non-clear state. 0 when clear."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Self-diagnostic confidence in the reported PCI."
    }
  },
  "required": ["sensorId", "sensorClass", "pci", "state", "dwellSeconds", "confidence"],
  "additionalProperties": false
}
