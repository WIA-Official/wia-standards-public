{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiastandards.com/perception-clarity/spec/schemas/pci.schema.json",
  "title": "Perception Clarity Index (PCI)",
  "description": "Per-sensor perception clarity score (0-100) with its three contributing axes and weights.",
  "type": "object",
  "properties": {
    "value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Perception Clarity Index. 100 = perfectly clear, 0 = fully blind."
    },
    "axes": {
      "type": "object",
      "properties": {
        "occlusion": { "type": "number", "minimum": 0, "maximum": 1, "description": "Occluded fraction of effective field of view." },
        "distanceDegradation": { "type": "number", "minimum": 0, "maximum": 1, "description": "Normalized loss of effective detection distance." },
        "mtfReduction": { "type": "number", "minimum": 0, "maximum": 1, "description": "Normalized reduction in contrast/MTF50." }
      },
      "required": ["occlusion", "distanceDegradation", "mtfReduction"],
      "additionalProperties": false
    },
    "weights": {
      "type": "object",
      "properties": {
        "occlusion": { "type": "number", "minimum": 0, "maximum": 1 },
        "distance": { "type": "number", "minimum": 0, "maximum": 1 },
        "mtf": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["occlusion", "distance", "mtf"],
      "additionalProperties": false,
      "description": "Sensor-class weights; the three values MUST sum to 1.0 (+/- 0.001)."
    }
  },
  "required": ["value"],
  "additionalProperties": false
}
