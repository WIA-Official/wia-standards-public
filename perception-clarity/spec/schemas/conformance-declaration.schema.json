{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiastandards.com/perception-clarity/spec/schemas/conformance-declaration.schema.json",
  "title": "Conformance Declaration",
  "description": "Vendor declaration of WIA Perception Clarity conformance for a product.",
  "type": "object",
  "properties": {
    "declaration_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "vendor": { "type": "string" },
    "product": { "type": "string" },
    "agentType": {
      "type": "string",
      "enum": ["vehicle", "robot", "drone", "amr", "other"]
    },
    "conformanceLevel": {
      "type": "string",
      "enum": ["L-A", "L-B", "L-C"]
    },
    "sensors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "sensorClass": {
            "type": "string",
            "enum": ["rgb_camera", "ir_thermal", "lidar_window", "radar_radome", "ultrasonic"]
          },
          "count": { "type": "integer", "minimum": 1 },
          "pciSupported": { "type": "boolean" },
          "reportingSupported": { "type": "boolean" },
          "dwellSlaSeconds": { "type": ["number", "null"], "minimum": 0 },
          "safeActionTriggers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["slow_down", "reroute", "trigger_cleaning", "safe_state", "disable_sensor"]
            }
          }
        },
        "required": ["sensorClass", "count", "pciSupported"],
        "additionalProperties": false
      }
    }
  },
  "required": ["declaration_id", "version", "vendor", "conformanceLevel", "sensors"],
  "additionalProperties": false
}
