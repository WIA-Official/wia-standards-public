{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiastandards.com/perception-clarity/spec/schemas/sensor-clarity-report.schema.json",
  "title": "Sensor Clarity Report",
  "description": "WIA Perception Clarity reporting message: a physical AI agent reporting per-sensor perception clarity.",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "messageId": { "type": "string", "description": "UUID for this report." },
        "timestamp": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" },
        "agentType": {
          "type": "string",
          "enum": ["vehicle", "robot", "drone", "amr", "other"]
        },
        "conformanceLevel": {
          "type": "string",
          "enum": ["L-A", "L-B", "L-C"]
        }
      },
      "required": ["version", "messageId", "timestamp", "agentId", "agentType"],
      "additionalProperties": false
    },
    "sensors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "sensor.schema.json" }
    }
  },
  "required": ["header", "sensors"],
  "additionalProperties": false
}
