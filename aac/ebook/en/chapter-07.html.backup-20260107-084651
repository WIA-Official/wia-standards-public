<h2>7.3 ISP Integration (Sign Language)</h2>

<h3>7.3.1 Overview</h3>

<p>ISP (International Sign Protocol) is the WIA standard for representing sign language digitally. It enables text-to-sign translation displayed via 3D avatars or video.</p>

<h3>7.3.2 Integration API</h3>

<pre>
import { WiaAAC } from 'wia-aac';
import { ISP, ISPAvatar } from 'wia-isp';

// Initialize
const aac = new WiaAAC();
const isp = new ISP();
const avatar = new ISPAvatar({
    model: 'standard-human',
    signLanguage: 'ASL'  // ASL, BSL, KSL, JSL, etc.
});

// Connect AAC to ISP
aac.on('text', async (text) =&gt; {
    // Convert text to sign language notation
    const signs = await isp.textToSigns(text);

    // Render avatar animation
    await avatar.animate(signs);
});

// Get ISP notation
aac.on('text', async (text) =&gt; {
    const ispNotation = await isp.textToISP(text);
    console.log(ispNotation);
    // Output: "[HELLO:wave+smile] [WORLD:sphere-gesture]"
});
</pre>

