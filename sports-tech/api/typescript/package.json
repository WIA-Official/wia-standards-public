{
  "name": "@wia/sports-tech",
  "version": "1.0.0",
  "description": "WIA-IND-011 Sports Tech Standard - TypeScript SDK for performance tracking, smart equipment, injury prevention, and training optimization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "docs": "typedoc --out docs src"
  },
  "keywords": [
    "wia",
    "sports",
    "sports-tech",
    "performance-tracking",
    "injury-prevention",
    "training-optimization",
    "smart-equipment",
    "wearables",
    "fitness",
    "athletics",
    "biometrics",
    "biomechanics",
    "sports-science",
    "standard",
    "WIA-IND-011",
    "홍익인간"
  ],
  "author": "WIA Technical Committee - Sports Technology Division",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/sports-tech/api/typescript"
  },
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "homepage": "https://wiastandards.com/sports-tech",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.16.0",
    "eventemitter3": "^5.0.1",
    "uuid": "^9.0.1",
    "protobufjs": "^7.2.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "rollup": "^4.9.6",
    "rollup-plugin-typescript2": "^0.36.0",
    "prettier": "^3.2.4",
    "typedoc": "^0.25.7"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/wia-standards"
  },
  "sideEffects": false
}
