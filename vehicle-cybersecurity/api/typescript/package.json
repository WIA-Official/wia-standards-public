{
  "name": "@wia/auto-023",
  "version": "1.0.0",
  "description": "WIA-AUTO-023: Vehicle Cybersecurity SDK - Comprehensive security framework for connected and autonomous vehicles",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "require": "./dist/types.js",
      "import": "./dist/types.mjs",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/types.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/types.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "docs": "typedoc src/index.ts",
    "security:audit": "npm audit",
    "security:scan": "snyk test"
  },
  "keywords": [
    "wia",
    "automotive",
    "cybersecurity",
    "vehicle-security",
    "can-bus",
    "ecu",
    "ota",
    "v2x",
    "ids",
    "intrusion-detection",
    "iso-21434",
    "unece-wp29",
    "automotive-security",
    "connected-vehicle",
    "autonomous-vehicle",
    "standard",
    "WIA-AUTO-023"
  ],
  "author": "WIA Automotive Security Group",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/vehicle-cybersecurity/api/typescript"
  },
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "homepage": "https://wiastandards.com/standards/WIA-AUTO-023",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-security": "^2.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "snyk": "^1.1277.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typedoc": "^0.25.6",
    "typescript": "^5.3.3"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 90,
    "tabWidth": 2,
    "arrowParens": "always"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:security/recommended",
      "prettier"
    ],
    "plugins": [
      "@typescript-eslint",
      "security",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-module-boundary-types": "off",
      "security/detect-object-injection": "warn",
      "security/detect-non-literal-regexp": "warn"
    }
  }
}
