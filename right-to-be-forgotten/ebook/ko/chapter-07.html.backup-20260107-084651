                <h2>7.8 통합 구현 예시</h2>

                <h3>전체 WIA 스택을 사용한 삭제 요청</h3>
                <pre><code>import { WIAOmniClient } from '@wia/omni-sdk';

const wia = new WIAOmniClient({
  apiKey: process.env.WIA_API_KEY
});

async function comprehensiveDeletion(userIntent) {
  // 1. WIA-INTENT: 자연어 의도 파싱
  const intent = await wia.intent.parse(userIntent);

  // 2. WIA-LEG-009: 삭제 요청 생성
  const deletionRequest = await wia.rtbf.createRequest({
    ...intent.toWIALEG009(),
    callback_url: "https://myapp.com/wia/callback"
  });

  // 3. WIA-SOCIAL: 소셜 플랫폼에 전파
  const socialDeletion = await wia.social.propagateDeletion({
    request_id: deletionRequest.id,
    auto_confirm: false  // 각 플랫폼에서 별도 확인
  });

  // 4. WIA-AIR-POWER: 대량 작업인 경우 분산 처리
  if (deletionRequest.estimated_records > 100000) {
    await wia.airPower.distributeJob({
      request_id: deletionRequest.id,
      parallelism: 10
    });
  }

  // 5. WIA-AIR-SHIELD: 보안 강화
  await wia.airShield.enableSecureErase({
    request_id: deletionRequest.id,
    method: "DOD_5220.22-M"
  });

  // 6. 진행 상황 모니터링
  const monitor = wia.omni.monitorRequest(deletionRequest.id);

  monitor.on('progress', (progress) => {
    console.log(`진행률: ${progress.percentage}%`);
  });

  monitor.on('completed', async (result) => {
    // 7. WIA-BLOCKCHAIN: NFT 인증서 발급
    const certificate = await wia.blockchain.mintCertificate({
      request_id: deletionRequest.id,
      recipient: userWalletAddress
    });

    console.log(`완료! NFT 인증서: ${certificate.tokenId}`);
    console.log(`OpenSea: https://opensea.io/assets/${certificate.contract}/${certificate.tokenId}`);
  });

  return deletionRequest;
}

// 사용
await comprehensiveDeletion(
  "GDPR에 따라 나의 모든 개인정보를 삭제하고, 블록체인 증명서를 받고 싶습니다."
);
</code></pre>
