            <section>
                <h2>7.3 WIA-INTENT 통합</h2>

                <p>
                    WIA-INTENT는 자연어 의도를 구조화된 요청으로 변환합니다.
                </p>

                <h3>자연어에서 WIA-LEG-009 요청으로</h3>
                <pre><code>// 사용자 입력
const userIntent = "나는 2020년부터 2023년까지의 모든 개인정보를 삭제하고 싶어요.
GDPR에 따라 요청합니다.";

// WIA-INTENT 처리
const intent = await WIAIntent.parse(userIntent);

// WIA-LEG-009 요청으로 변환
const rtbfRequest = intent.toWIALEG009({
  dataSubject: {
    email: currentUser.email,
    identifiers: currentUser.identifiers
  }
});

// 결과
{
  "wia_standard": "WIA-LEG-009",
  "version": "1.0",
  "request_type": "deletion",
  "legal_basis": "GDPR_Article_17_1a",
  "scope": {
    "data_categories": ["all_personal_data"],
    "time_range": {
      "start": "2020-01-01T00:00:00Z",
      "end": "2023-12-31T23:59:59Z"
    }
  },
  "source_intent": {
    "wia_standard": "WIA-INTENT",
    "original_text": "나는 2020년부터...",
    "confidence": 0.95
  }
}</code></pre>

