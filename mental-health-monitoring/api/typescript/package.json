{
  "name": "@wia/mental-health",
  "version": "1.0.0",
  "description": "WIA Mental Health Monitoring Standard SDK - Integrated mental health assessment, treatment, and monitoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wia",
    "mental-health",
    "healthcare",
    "assessment",
    "therapy",
    "psychedelic",
    "digital-therapeutics",
    "neuroplasticity",
    "phq-9",
    "gad-7",
    "crisis-intervention",
    "telehealth",
    "fhir",
    "hipaa"
  ],
  "author": "WIA Mental Health Research Group",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/mental-health-monitoring/api/typescript"
  },
  "homepage": "https://wiastandards.com/mental-health-monitoring",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
