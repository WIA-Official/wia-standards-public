        <pre><code>// 1. 사용자가 WIA-INTENT로 자연어 입력
const intent = await wiaIntent.parse({
  text: "내 암호화폐를 아이들에게 똑같이 나눠주고, 25세 이후에 받게 해주세요",
  language: "ko"
});

// 2. WIA-SOCIAL로 수혜자 검증
const verifiedBeneficiaries = await wiaSocial.verifyRelationships({
  owner: "did:wia:0x...owner",
  beneficiaries: intent.beneficiaries
});

// 3. WIA-LEG-006으로 계획 생성
const plan = await wiaLeg006.createPlan({
  intent: intent,
  beneficiaries: verifiedBeneficiaries,
  securityLevel: "platinum"
});

// 4. WIA-AIR-SHIELD로 보안 강화
const securedPlan = await wiaAirShield.encrypt({
  plan: plan,
  encryptionScheme: "quantum-resistant"
});

// 5. WIA-OMNI-API로 전체 오케스트레이션
const result = await wiaOmni.execute({
  workflow: "complete-inheritance-setup",
  steps: [intent, verification, plan, security]
});</code></pre>

        <div class="key-takeaways">
            <h3>핵심 요약</h3>
            <ol>
                <li><strong>생태계 접근:</strong> WIA-LEG-006은 독립형이 아닌 통합 표준 패밀리의 일부입니다</li>
                <li><strong>소셜 검증:</strong> WIA-SOCIAL은 분산 신원 확인과 소셜 복구를 제공합니다</li>
                <li><strong>자연어 인터페이스:</strong> WIA-INTENT는 기술적 전문 지식 없이 계획 생성을 가능하게 합니다</li>
                <li><strong>통합 API:</strong> WIA-OMNI-API는 모든 표준에 대한 단일 액세스 포인트를 제공합니다</li>
                <li><strong>강화된 보안:</strong> WIA-AIR-SHIELD는 양자 저항 암호화와 제로 지식 증명을 추가합니다</li>
                <li><strong>인증 중요성:</strong> WIA 인증은 상호 운용성과 품질을 보장합니다</li>
            </ol>
        </div>

