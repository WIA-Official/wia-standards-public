    "directory": "standards/WIA-MACHINE_VISION"
  },
  "dependencies": {
    "onnxruntime-node": "^1.17.0",
    "sharp": "^0.33.0",
    "canvas": "^2.11.2",
    "jimp": "^0.22.10",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
