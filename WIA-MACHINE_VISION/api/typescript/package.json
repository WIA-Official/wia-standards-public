{
  "name": "@wia/machine-vision",
  "version": "1.0.0",
  "description": "WIA Machine Vision SDK - Computer vision, object detection, image classification, and deep learning inference",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
