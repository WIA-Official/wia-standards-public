{
  "name": "@wia/hydrogen-energy-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for WIA-ENE-007 Hydrogen Energy Standard - 弘益人間 (Benefit All Humanity)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hydrogen",
    "energy",
    "clean-energy",
    "wia",
    "standard",
    "electrolysis",
    "fuel-cell",
    "green-hydrogen",
    "renewable-energy",
    "sustainability"
  ],
  "author": "SmileStory Inc. / WIA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "hydrogen-energy/api/typescript"
  },
  "homepage": "https://wia.org/standards/ene-007",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {},
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
