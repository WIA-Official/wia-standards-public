{
  "name": "@wia/tls-lite",
  "version": "1.0.0",
  "description": "WIA-TLS-LITE - Lightweight Transport Layer Security for IoT and Constrained Devices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "wia",
    "tls",
    "tls-lite",
    "iot",
    "security",
    "transport-layer",
    "lightweight",
    "constrained-devices",
    "encryption",
    "handshake",
    "certificate",
    "cipher-suite",
    "session-resumption",
    "alpn",
    "sni"
  ],
  "author": "WIA (World Certification Industry Association)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/WIA-TLS-LITE/api/typescript"
  },
  "homepage": "https://github.com/WIA-Official/wia-standards/tree/main/standards/WIA-TLS-LITE",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
