<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><link rel="icon" type="image/x-icon" href="/favicon.ico"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>WIA Rust Intermediate - Intermediate Rust Standard</title><style>:root{--primary:#3B82F6;--secondary:#10b981;--bg:#0f172a;--bg-card:#1e293b;--text:#f8fafc;--text-muted:#94a3b8;--border:#334155}*{margin:0;padding:0;box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;line-height:1.6}.container{max-width:1100px;margin:0 auto;padding:20px}.top-nav{display:flex;justify-content:space-between;align-items:center;padding:15px 0;border-bottom:1px solid var(--border);margin-bottom:20px}.nav-home{color:var(--text);text-decoration:none;font-weight:bold;font-size:1.1rem}.nav-right{display:flex;align-items:center;gap:25px}.nav-links{display:flex;gap:20px}.nav-links a{color:var(--text-muted);text-decoration:none;font-size:.85rem}.lang-switch{display:flex;gap:5px}.lang-btn{padding:6px 12px;border:1px solid var(--border);background:transparent;color:var(--text-muted);border-radius:6px;cursor:pointer;font-size:.85rem}.lang-btn.active{background:var(--primary);color:white}.hero{text-align:center;padding:40px 0}.hero-emoji{font-size:80px;margin-bottom:20px;animation:float 3s ease-in-out infinite}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}.hero h1{font-size:2.8rem;margin-bottom:10px;background:linear-gradient(90deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent}.hero .subtitle{font-size:1.2rem;color:var(--text-muted);margin-bottom:15px}.hero .desc{font-size:1.05rem;color:var(--text-muted);max-width:700px;margin:0 auto 30px}.actions{display:flex;justify-content:center;gap:15px;margin:30px 0}.btn{padding:14px 28px;border-radius:10px;text-decoration:none;font-weight:600;font-size:1rem}.btn-primary{background:linear-gradient(135deg,var(--primary),#2563EB);color:white}.btn-secondary{background:var(--bg-card);color:var(--text);border:1px solid var(--border)}.section-title{font-size:1.5rem;text-align:center;margin:50px 0 25px}.phases{display:grid;grid-template-columns:repeat(2,1fr);gap:15px;margin:30px auto;max-width:500px}.phase{background:var(--bg-card);padding:25px 20px;border-radius:12px;text-decoration:none;color:var(--text);border:1px solid var(--border);text-align:center}.phase.done{border-color:var(--secondary)}.phase-num{font-size:2rem;font-weight:bold;color:var(--primary)}.phase-title{font-size:.95rem;color:var(--text-muted);margin-top:8px}.phase-status{margin-top:10px;font-size:.85rem;color:var(--secondary)}.badges{display:flex;justify-content:center;flex-wrap:wrap;gap:10px;margin:30px 0}.badge{background:rgba(59,130,246,.15);color:var(--primary);padding:8px 16px;border-radius:20px;font-size:.9rem;border:1px solid rgba(59,130,246,.3)}.links{display:flex;justify-content:center;gap:15px;margin:40px 0}.links a{color:var(--text-muted);text-decoration:none;padding:10px 20px;border:1px solid var(--border);border-radius:8px;font-size:.9rem}footer{margin-top:60px;padding:30px 0;border-top:1px solid var(--border);text-align:center}footer .philosophy{color:#ffd700;font-size:1.1rem;margin-bottom:10px}footer p{color:var(--text-muted);margin:5px 0}@media(max-width:768px){.top-nav{flex-direction:column;gap:15px}.hero h1{font-size:2rem}}</style></head>
<body><div class="container"><div class="top-nav"><a href="https://wiastandards.com" class="nav-home" target="_blank">🤟 WIA Standards</a><div class="nav-right"><nav class="nav-links"><a href="simulator/">🎮 Simulator</a><a href="ebook/en/">📚 Ebook</a></nav><div class="lang-switch"><button class="lang-btn active" onclick="setLang('en')">EN</button><button class="lang-btn" onclick="setLang('ko')">KO</button></div></div></div><section class="hero"><div class="hero-emoji">🦀</div><h1 data-en="WIA Rust Intermediate" data-ko="WIA Rust 중급">WIA Rust Intermediate</h1><p class="subtitle" data-en="Intermediate Rust Standard v1.0.0" data-ko="중급 Rust 표준 v1.0.0">Intermediate Rust Standard v1.0.0</p><p class="desc" data-en="Open standard for intermediate Rust. Ownership • Lifetimes • Traits • Error Handling" data-ko="중급 Rust를 위한 개방형 표준.">Open standard for intermediate Rust.</p></section><div class="actions"><a href="simulator/" class="btn btn-primary">🎮 Try Simulator</a><a href="ebook/en/" class="btn btn-secondary">📚 Read Ebook</a></div><h2 class="section-title">📋 Specification Phases</h2><div class="phases"><a href="spec/" class="phase done"><div class="phase-num">1</div><div class="phase-title">Foundation</div><div class="phase-status">✅ Complete</div></a><a href="spec/" class="phase done"><div class="phase-num">2</div><div class="phase-title">Implementation</div><div class="phase-status">✅ Complete</div></a><a href="spec/" class="phase done"><div class="phase-num">3</div><div class="phase-title">Advanced</div><div class="phase-status">✅ Complete</div></a><a href="spec/" class="phase done"><div class="phase-num">4</div><div class="phase-title">Integration</div><div class="phase-status">✅ Complete</div></a></div><div class="badges"><span class="badge">📦 Ownership</span><span class="badge">⏳ Lifetimes</span><span class="badge">🧩 Traits</span><span class="badge">⚠️ Errors</span></div><div class="links"><a href="https://github.com/WIA-Official/wia-standards/tree/main/wia-rust-intermediate" target="_blank">📦 GitHub</a><a href="api/typescript/">📘 TypeScript SDK</a><a href="spec/">📄 Specs</a></div><footer><p class="philosophy">弘益人間 · Benefit All Humanity</p><p>© <span class="dynamic-year">2025</span> WIA MIT License</p></footer></div><script>let currentLang=localStorage.getItem('wiaLang')||'en';function setLang(lang){currentLang=lang;localStorage.setItem('wiaLang',lang);document.querySelectorAll('[data-en]').forEach(el=>{el.textContent=el.getAttribute('data-'+lang)});document.querySelectorAll('.lang-btn').forEach(btn=>{btn.classList.toggle('active',btn.textContent.toLowerCase()===lang)})}document.addEventListener('DOMContentLoaded',function(){setLang(currentLang)})</script><script>
document.addEventListener("DOMContentLoaded", function() {
    const currentYear = new Date().getFullYear();
    document.querySelectorAll(".dynamic-year").forEach(el => {
        el.textContent = currentYear;
    });
});
</script>
</body></html>
