      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(wia_security_events_total)",
          "legendFormat": "__auto",
          "range": true,
          "refId": "A"
        }
      ],
