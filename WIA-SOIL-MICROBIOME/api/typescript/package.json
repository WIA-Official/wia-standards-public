{
  "name": "@wia/soil-microbiome-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the WIA-SOIL-MICROBIOME Standard - Soil Health and Microbiome Analysis",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wia",
    "soil",
    "microbiome",
    "soil-health",
    "agriculture",
    "carbon-sequestration",
    "biodiversity",
    "sustainability",
    "climate",
    "regenerative-agriculture",
    "interoperability",
    "standard"
  ],
  "author": "WIA - World Certification Industry Association",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/WIA-SOIL-MICROBIOME/api/typescript"
  },
  "homepage": "https://wiastandards.com/soil-microbiome",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
