{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wia.standards/cicd/schemas/provenance.schema.json",
  "title": "WIA-CICD SLSA in-toto Provenance Statement",
  "description": "Subset of in-toto Statement v1 carrying SLSA Provenance v1 predicate. WIA-CICD targets SLSA L3.",
  "type": "object",
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type":         { "const": "https://in-toto.io/Statement/v1" },
    "predicateType": { "const": "https://slsa.dev/provenance/v1" },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "digest"],
        "properties": {
          "name":   { "type": "string", "minLength": 1 },
          "digest": {
            "type": "object",
            "minProperties": 1,
            "patternProperties": { "^(sha256|sha512|sha1)$": { "type": "string", "minLength": 8 } },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "predicate": {
      "type": "object",
      "required": ["buildDefinition", "runDetails"],
      "properties": {
        "buildDefinition": {
          "type": "object",
          "required": ["buildType", "externalParameters"],
          "properties": {
            "buildType":            { "type": "string", "format": "uri" },
            "externalParameters":   { "type": "object" },
            "internalParameters":   { "type": "object" },
            "resolvedDependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["uri"],
                "properties": {
                  "uri":    { "type": "string", "format": "uri" },
                  "digest": { "type": "object" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "runDetails": {
          "type": "object",
          "required": ["builder"],
          "properties": {
            "builder": {
              "type": "object",
              "required": ["id"],
              "properties": { "id": { "type": "string", "format": "uri" } },
              "additionalProperties": false
            },
            "metadata": {
              "type": "object",
              "properties": {
                "invocationId": { "type": "string" },
                "startedOn":    { "type": "string", "format": "date-time" },
                "finishedOn":   { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            },
            "byproducts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name":   { "type": "string" },
                  "digest": { "type": "object" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
