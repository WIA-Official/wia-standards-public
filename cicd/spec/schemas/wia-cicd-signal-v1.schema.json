{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wia.standards/cicd/schemas/wia-cicd-signal-v1.schema.json",
  "title": "WIA-CICD Wire Signal v1",
  "description": "Single envelope forwarding DORA, cache, security and SLO signals over OTLP/JSON.",
  "type": "object",
  "required": ["signal", "ts", "source"],
  "properties": {
    "signal": { "const": "wia-cicd-signal-v1" },
    "ts":     { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["pipeline", "node"],
      "properties": {
        "pipeline": { "type": "string" },
        "node":     { "type": "string", "enum": ["SOURCE", "BUILD", "TEST_GATE", "SECURITY_GATE", "CD_HANDOFF"] }
      },
      "additionalProperties": false
    },
    "dora": {
      "type": "object",
      "properties": {
        "lead_time_hr": { "type": "number", "minimum": 0 },
        "failure_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "mttr_min":     { "type": "number", "minimum": 0 },
        "rework_rate":  { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "cache": {
      "type": "object",
      "properties": {
        "local":     { "type": "number", "minimum": 0, "maximum": 1 },
        "remote":    { "type": "number", "minimum": 0, "maximum": 1 },
        "execution": { "type": "number", "minimum": 0, "maximum": 1 },
        "overall":   { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "properties": {
        "policy":   { "type": "string", "enum": ["AUDIT", "ENFORCE"] },
        "fp_rate":  { "type": "number", "minimum": 0, "maximum": 1 },
        "critical": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "slo": {
      "type": "object",
      "properties": {
        "tier":   { "type": "string", "enum": ["STD", "FIN"] },
        "target": { "type": "number", "minimum": 0.99, "maximum": 0.99999 },
        "burned": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "korea_context": {
      "type": "object",
      "properties": {
        "act":         { "type": "string" },
        "categories":  { "type": "array", "items": { "type": "string" } },
        "reporter":    { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
