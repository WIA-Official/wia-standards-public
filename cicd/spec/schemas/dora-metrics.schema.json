{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wia.standards/cicd/schemas/dora-metrics.schema.json",
  "title": "WIA-CICD DORA + Rework Rate Envelope",
  "description": "Five-axis pipeline performance envelope. Elite thresholds match the simulator constants.",
  "type": "object",
  "required": ["window_days", "metrics"],
  "properties": {
    "window_days": { "type": "integer", "minimum": 1, "maximum": 365 },
    "metrics": {
      "type": "object",
      "required": ["lead_time_hr", "deploy_freq_per_day", "failure_rate", "mttr_min", "rework_rate"],
      "properties": {
        "lead_time_hr":         { "type": "number", "minimum": 0 },
        "deploy_freq_per_day":  { "type": "number", "minimum": 0 },
        "failure_rate":         { "type": "number", "minimum": 0, "maximum": 1 },
        "mttr_min":             { "type": "number", "minimum": 0 },
        "rework_rate":          { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "elite_thresholds": {
      "type": "object",
      "description": "Mirror of simulator constants. Implementations SHOULD assert observed metrics ≤ these values.",
      "properties": {
        "lead_time_hr":  { "const": 1 },
        "failure_rate":  { "const": 0.05 },
        "mttr_min":      { "const": 5 },
        "rework_rate":   { "const": 0.05 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
