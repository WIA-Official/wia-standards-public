<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WIA Pet Health Passport - Interactive Simulator</title>
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --secondary: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg: #0f172a;
            --bg-card: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --border: #334155;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.6;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }

        /* Header */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 30px;
        }
        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--primary);
        }
        .lang-switch {
            display: flex;
            gap: 10px;
        }
        .lang-btn {
            padding: 8px 16px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text);
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .lang-btn.active {
            background: var(--primary);
            border-color: var(--primary);
        }
        .lang-btn:hover { border-color: var(--primary); }

        /* Hero */
        .hero {
            text-align: center;
            padding: 40px 0;
        }
        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 15px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero p { color: var(--text-muted); font-size: 1.1rem; }

        /* Tabs */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }
        .tab {
            padding: 12px 24px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .tab.active {
            background: var(--primary);
            border-color: var(--primary);
        }
        .tab:hover { border-color: var(--primary); }

        /* Panel */
        .panel {
            display: none;
            background: var(--bg-card);
            border-radius: 12px;
            padding: 30px;
            border: 1px solid var(--border);
        }
        .panel.active { display: block; }
        .panel h2 {
            margin-bottom: 20px;
            color: var(--primary);
        }

        /* Form */
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            border-radius: 8px;
            font-size: 1rem;
        }
        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--primary);
        }
        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        /* Buttons */
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-primary {
            background: var(--primary);
            color: white;
        }
        .btn-primary:hover { background: var(--primary-dark); }
        .btn-secondary {
            background: var(--secondary);
            color: white;
        }
        .btn-outline {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text);
        }
        .btn-outline:hover { border-color: var(--primary); }

        /* Passport Card */
        .passport-card {
            background: linear-gradient(135deg, #1e3a5f, #0f172a);
            border-radius: 16px;
            padding: 30px;
            border: 2px solid var(--primary);
            position: relative;
            overflow: hidden;
        }
        .passport-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.2), transparent);
        }
        .passport-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 25px;
        }
        .passport-title {
            font-size: 1.2rem;
            color: var(--primary);
            margin-bottom: 5px;
        }
        .passport-id {
            font-family: monospace;
            color: var(--text-muted);
            font-size: 0.85rem;
        }
        .passport-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
        }
        .status-valid { background: var(--secondary); color: white; }
        .status-expired { background: var(--danger); color: white; }
        .status-pending { background: var(--warning); color: black; }

        .passport-photo {
            width: 120px;
            height: 120px;
            border-radius: 12px;
            background: var(--bg);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 0.8rem;
        }
        .passport-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
        .info-item label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .info-item span {
            display: block;
            font-size: 1rem;
            margin-top: 3px;
        }

        /* Vaccination Table */
        .vacc-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        .vacc-table th,
        .vacc-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }
        .vacc-table th {
            background: var(--bg);
            color: var(--text-muted);
            font-size: 0.85rem;
            text-transform: uppercase;
        }
        .vacc-badge {
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 0.8rem;
        }
        .badge-valid { background: rgba(16, 185, 129, 0.2); color: var(--secondary); }
        .badge-due { background: rgba(245, 158, 11, 0.2); color: var(--warning); }
        .badge-overdue { background: rgba(239, 68, 68, 0.2); color: var(--danger); }

        /* Quarantine Check */
        .quarantine-result {
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
        }
        .quarantine-pass {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid var(--secondary);
        }
        .quarantine-fail {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid var(--danger);
        }
        .quarantine-result h3 {
            margin-bottom: 10px;
        }
        .requirement-list {
            list-style: none;
        }
        .requirement-list li {
            padding: 8px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .check-icon { color: var(--secondary); }
        .cross-icon { color: var(--danger); }

        /* QR Code */
        .qr-section {
            text-align: center;
            padding: 30px;
            background: var(--bg);
            border-radius: 12px;
            margin-top: 20px;
        }
        .qr-code {
            width: 200px;
            height: 200px;
            background: white;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #333;
            font-size: 0.8rem;
        }

        /* CTA */
        .cta-section {
            margin-top: 50px;
            padding: 40px;
            background: linear-gradient(135deg, var(--bg-card), var(--bg));
            border-radius: 16px;
            border: 1px solid var(--border);
            text-align: center;
        }
        .cta-section h2 { margin-bottom: 15px; }
        .cta-section p { color: var(--text-muted); margin-bottom: 25px; }
        .cta-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .price-tag {
            font-size: 2rem;
            font-weight: bold;
            color: var(--secondary);
            margin: 15px 0;
        }

        /* Footer */
        footer {
            margin-top: 50px;
            padding: 30px 0;
            border-top: 1px solid var(--border);
            text-align: center;
            color: var(--text-muted);
        }
        footer a { color: var(--primary); text-decoration: none; }

        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 { font-size: 1.8rem; }
            .passport-info { grid-template-columns: 1fr; }
            .tabs { justify-content: center; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo">[PET] WIA Pet Health Passport</div>
            <div class="lang-switch">
                <button class="lang-btn active" onclick="setLang('en')">EN</button>
                <button class="lang-btn" onclick="setLang('ko')">KO</button>
            </div>
        </header>

        <section class="hero">
            <h1 data-en="Pet Health Passport Simulator" data-ko="반려동물 건강여권 시뮬레이터"></h1>
            <p data-en="Interactive demo of WIA-PET-HEALTH-PASSPORT standard"
               data-ko="WIA-PET-HEALTH-PASSPORT 표준 인터랙티브 데모"></p>
        </section>

        <div class="tabs">
            <button class="tab active" onclick="showPanel('create')"
                    data-en="Create Passport" data-ko="여권 생성"></button>
            <button class="tab" onclick="showPanel('view')"
                    data-en="View Passport" data-ko="여권 조회"></button>
            <button class="tab" onclick="showPanel('vaccination')"
                    data-en="Vaccination Records" data-ko="백신 기록"></button>
            <button class="tab" onclick="showPanel('quarantine')"
                    data-en="Quarantine Check" data-ko="검역 확인"></button>
            <button class="tab" onclick="showPanel('qr')"
                    data-en="QR Code" data-ko="QR 코드"></button>
        </div>

        <!-- Create Panel -->
        <div id="create" class="panel active">
            <h2 data-en="Create New Pet Passport" data-ko="새 반려동물 여권 생성"></h2>

            <div class="form-row">
                <div class="form-group">
                    <label data-en="Pet Name" data-ko="반려동물 이름"></label>
                    <input type="text" id="petName" placeholder="Max">
                </div>
                <div class="form-group">
                    <label data-en="Species" data-ko="종"></label>
                    <select id="petSpecies">
                        <option value="dog" data-en="Dog" data-ko="개">Dog</option>
                        <option value="cat" data-en="Cat" data-ko="고양이">Cat</option>
                        <option value="rabbit" data-en="Rabbit" data-ko="토끼">Rabbit</option>
                        <option value="bird" data-en="Bird" data-ko="새">Bird</option>
                        <option value="other" data-en="Other" data-ko="기타">Other</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label data-en="Breed" data-ko="품종"></label>
                    <input type="text" id="petBreed" placeholder="Golden Retriever">
                </div>
                <div class="form-group">
                    <label data-en="Date of Birth" data-ko="생년월일"></label>
                    <input type="date" id="petDob">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label data-en="Sex" data-ko="성별"></label>
                    <select id="petSex">
                        <option value="male" data-en="Male" data-ko="수컷">Male</option>
                        <option value="female" data-en="Female" data-ko="암컷">Female</option>
                        <option value="neutered_male" data-en="Neutered Male" data-ko="중성화 수컷">Neutered Male</option>
                        <option value="spayed_female" data-en="Spayed Female" data-ko="중성화 암컷">Spayed Female</option>
                    </select>
                </div>
                <div class="form-group">
                    <label data-en="Color" data-ko="모색"></label>
                    <input type="text" id="petColor" placeholder="Golden">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label data-en="Microchip ID (15 digits)" data-ko="마이크로칩 ID (15자리)"></label>
                    <input type="text" id="microchipId" placeholder="900123456789012" maxlength="15">
                </div>
                <div class="form-group">
                    <label data-en="Weight (kg)" data-ko="체중 (kg)"></label>
                    <input type="number" id="petWeight" placeholder="25.5" step="0.1">
                </div>
            </div>

            <div class="form-group">
                <label data-en="Owner Name" data-ko="보호자 이름"></label>
                <input type="text" id="ownerName" placeholder="John Smith">
            </div>

            <button class="btn btn-primary" onclick="createPassport()"
                    data-en="[+] Create Passport" data-ko="[+] 여권 생성"></button>
        </div>

        <!-- View Panel -->
        <div id="view" class="panel">
            <h2 data-en="Pet Passport" data-ko="반려동물 여권"></h2>

            <div class="passport-card">
                <div class="passport-header">
                    <div>
                        <div class="passport-title">WIA PET HEALTH PASSPORT</div>
                        <div class="passport-id" id="displayPassportId">PHP-2025-XXXX-XXXX</div>
                    </div>
                    <div class="passport-status status-valid" id="passportStatus"
                         data-en="VALID" data-ko="유효"></div>
                </div>

                <div style="display: flex; gap: 30px; flex-wrap: wrap;">
                    <div class="passport-photo" id="petPhoto"
                         data-en="[Photo]" data-ko="[사진]">[Photo]</div>

                    <div class="passport-info" style="flex: 1;">
                        <div class="info-item">
                            <label data-en="NAME" data-ko="이름">NAME</label>
                            <span id="displayName">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="SPECIES" data-ko="종">SPECIES</label>
                            <span id="displaySpecies">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="BREED" data-ko="품종">BREED</label>
                            <span id="displayBreed">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="DOB" data-ko="생년월일">DOB</label>
                            <span id="displayDob">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="SEX" data-ko="성별">SEX</label>
                            <span id="displaySex">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="COLOR" data-ko="모색">COLOR</label>
                            <span id="displayColor">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="MICROCHIP" data-ko="마이크로칩">MICROCHIP</label>
                            <span id="displayMicrochip">-</span>
                        </div>
                        <div class="info-item">
                            <label data-en="OWNER" data-ko="보호자">OWNER</label>
                            <span id="displayOwner">-</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vaccination Panel -->
        <div id="vaccination" class="panel">
            <h2 data-en="Vaccination Records" data-ko="백신 기록"></h2>

            <div class="form-row" style="margin-bottom: 20px;">
                <div class="form-group">
                    <label data-en="Vaccine Type" data-ko="백신 종류"></label>
                    <select id="vaccineType">
                        <option value="rabies">Rabies / 광견병</option>
                        <option value="dhpp">DHPP (Distemper)</option>
                        <option value="bordetella">Bordetella</option>
                        <option value="leptospirosis">Leptospirosis</option>
                        <option value="fvrcp">FVRCP (Cats)</option>
                        <option value="felv">FeLV (Cats)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label data-en="Date Administered" data-ko="접종일"></label>
                    <input type="date" id="vaccineDate">
                </div>
                <div class="form-group">
                    <label data-en="Veterinarian" data-ko="수의사"></label>
                    <input type="text" id="vetName" placeholder="Dr. Smith">
                </div>
            </div>
            <button class="btn btn-secondary" onclick="addVaccination()"
                    data-en="[+] Add Vaccination" data-ko="[+] 백신 추가"></button>

            <table class="vacc-table">
                <thead>
                    <tr>
                        <th data-en="Vaccine" data-ko="백신">Vaccine</th>
                        <th data-en="Date" data-ko="접종일">Date</th>
                        <th data-en="Veterinarian" data-ko="수의사">Veterinarian</th>
                        <th data-en="Valid Until" data-ko="유효기간">Valid Until</th>
                        <th data-en="Status" data-ko="상태">Status</th>
                    </tr>
                </thead>
                <tbody id="vaccineTableBody">
                    <tr>
                        <td>Rabies</td>
                        <td>2024-06-15</td>
                        <td>Dr. Kim</td>
                        <td>2025-06-15</td>
                        <td><span class="vacc-badge badge-valid" data-en="Valid" data-ko="유효">Valid</span></td>
                    </tr>
                    <tr>
                        <td>DHPP</td>
                        <td>2024-03-10</td>
                        <td>Dr. Park</td>
                        <td>2025-03-10</td>
                        <td><span class="vacc-badge badge-due" data-en="Due Soon" data-ko="곧 만료">Due Soon</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Quarantine Panel -->
        <div id="quarantine" class="panel">
            <h2 data-en="Quarantine Eligibility Check" data-ko="검역 적격성 확인"></h2>

            <div class="form-row">
                <div class="form-group">
                    <label data-en="Destination Country" data-ko="목적지 국가"></label>
                    <select id="destCountry">
                        <option value="US">United States / 미국</option>
                        <option value="UK">United Kingdom / 영국</option>
                        <option value="JP">Japan / 일본</option>
                        <option value="AU">Australia / 호주</option>
                        <option value="EU">European Union / 유럽연합</option>
                        <option value="KR">South Korea / 대한민국</option>
                    </select>
                </div>
                <div class="form-group">
                    <label data-en="Travel Date" data-ko="여행 날짜"></label>
                    <input type="date" id="travelDate">
                </div>
            </div>

            <button class="btn btn-primary" onclick="checkQuarantine()"
                    data-en="[CHECK] Verify Eligibility" data-ko="[CHECK] 적격성 확인"></button>

            <div id="quarantineResult" class="quarantine-result quarantine-pass" style="display: none;">
                <h3 id="quarantineTitle" data-en="[OK] Entry Permitted" data-ko="[OK] 입국 가능"></h3>
                <p id="quarantineDesc" data-en="Your pet meets all requirements for the selected destination."
                   data-ko="선택한 목적지의 모든 요건을 충족합니다."></p>

                <ul class="requirement-list" id="requirementList">
                    <li><span class="check-icon">[OK]</span> <span data-en="Rabies vaccination valid" data-ko="광견병 백신 유효">Rabies vaccination valid</span></li>
                    <li><span class="check-icon">[OK]</span> <span data-en="Microchip registered" data-ko="마이크로칩 등록됨">Microchip registered</span></li>
                    <li><span class="check-icon">[OK]</span> <span data-en="Health certificate available" data-ko="건강증명서 보유">Health certificate available</span></li>
                    <li><span class="check-icon">[OK]</span> <span data-en="Tapeworm treatment (EU only)" data-ko="촌충 치료 (EU만 해당)">Tapeworm treatment (EU only)</span></li>
                </ul>
            </div>
        </div>

        <!-- QR Panel -->
        <div id="qr" class="panel">
            <h2 data-en="Passport QR Code" data-ko="여권 QR 코드"></h2>

            <div class="qr-section">
                <div class="qr-code" id="qrCodeDisplay">
                    [QR CODE]<br>
                    PHP-2025-XXXX
                </div>
                <p data-en="Scan this QR code to verify passport authenticity"
                   data-ko="이 QR 코드를 스캔하여 여권 진위를 확인하세요"></p>
                <p style="color: var(--text-muted); font-size: 0.85rem;"
                   data-en="Valid for 24 hours from generation"
                   data-ko="생성 후 24시간 동안 유효"></p>

                <div style="margin-top: 20px;">
                    <button class="btn btn-outline" onclick="regenerateQR()"
                            data-en="[REFRESH] Regenerate QR" data-ko="[REFRESH] QR 재생성"></button>
                    <button class="btn btn-outline" onclick="downloadQR()"
                            data-en="[DOWNLOAD] Download" data-ko="[DOWNLOAD] 다운로드"></button>
                </div>
            </div>

            <div style="margin-top: 20px; padding: 15px; background: var(--bg); border-radius: 8px;">
                <p style="font-size: 0.9rem; color: var(--text-muted);">
                    <strong data-en="Verification URL:" data-ko="검증 URL:">Verification URL:</strong><br>
                    <code>https://verify.wia.live/pet/PHP-2025-XXXX-XXXX</code>
                </p>
            </div>
        </div>

        <!-- CTA Section -->
        <section class="cta-section">
            <h2 data-en="Master the WIA Pet Health Passport Standard"
                data-ko="WIA 반려동물 건강여권 표준 마스터하기"></h2>
            <p data-en="Get the official ebook with complete specifications, implementation guides, and certification preparation materials."
               data-ko="공식 전자책으로 완전한 사양, 구현 가이드 및 인증 준비 자료를 받으세요."></p>

            <div class="price-tag">$99 USD</div>

            <div class="cta-buttons">
                <a href="../ebook/index.html" class="btn btn-primary"
                   data-en="[BOOK] Get the Ebook" data-ko="[BOOK] 전자책 구매"></a>
                <a href="https://wia.live/certifications/pet-health-passport" target="_blank"
                   class="btn btn-secondary"
                   data-en="[CERT] Get Certified" data-ko="[CERT] 인증 받기"></a>
            </div>
        </section>

        <footer>
            <p>WIA - World Certification Industry Association</p>
            <p data-en="Philosophy: Hongik Ingan - Benefit All Humanity"
               data-ko="철학: 홍익인간 (弘益人間)"></p>
            <p style="margin-top: 10px;">
                <a href="https://github.com/WIA-Official/wia-standards" target="_blank">GitHub</a> |
                <a href="https://wia.live" target="_blank">WIA Standards</a> |
                <a href="../README.md">Documentation</a>
            </p>
        </footer>
    </div>

    <script>
        let currentLang = 'en';
        let passportData = null;
        let vaccinations = [];

        function setLang(lang) {
            currentLang = lang;
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            document.querySelectorAll('[data-en]').forEach(el => {
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.placeholder = el.getAttribute('data-' + lang) || el.getAttribute('data-en');
                } else if (el.tagName === 'OPTION') {
                    el.textContent = el.getAttribute('data-' + lang) || el.getAttribute('data-en');
                } else {
                    el.textContent = el.getAttribute('data-' + lang) || el.getAttribute('data-en');
                }
            });
        }

        function showPanel(panelId) {
            document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.getElementById(panelId).classList.add('active');
            event.target.classList.add('active');
        }

        function generatePassportId() {
            const year = new Date().getFullYear();
            const random1 = Math.random().toString(36).substr(2, 4).toUpperCase();
            const random2 = Math.random().toString(36).substr(2, 4).toUpperCase();
            return `PHP-${year}-${random1}-${random2}`;
        }

        function createPassport() {
            const name = document.getElementById('petName').value || 'Unknown';
            const species = document.getElementById('petSpecies').value;
            const breed = document.getElementById('petBreed').value || 'Unknown';
            const dob = document.getElementById('petDob').value || 'Unknown';
            const sex = document.getElementById('petSex').value;
            const color = document.getElementById('petColor').value || 'Unknown';
            const microchip = document.getElementById('microchipId').value || 'Not registered';
            const owner = document.getElementById('ownerName').value || 'Unknown';

            passportData = {
                id: generatePassportId(),
                name, species, breed, dob, sex, color, microchip, owner,
                createdAt: new Date().toISOString()
            };

            // Update display
            document.getElementById('displayPassportId').textContent = passportData.id;
            document.getElementById('displayName').textContent = name;
            document.getElementById('displaySpecies').textContent = species.charAt(0).toUpperCase() + species.slice(1);
            document.getElementById('displayBreed').textContent = breed;
            document.getElementById('displayDob').textContent = dob;
            document.getElementById('displaySex').textContent = sex.replace('_', ' ').toUpperCase();
            document.getElementById('displayColor').textContent = color;
            document.getElementById('displayMicrochip').textContent = microchip;
            document.getElementById('displayOwner').textContent = owner;

            // Update QR
            document.getElementById('qrCodeDisplay').innerHTML = `[QR CODE]<br>${passportData.id}`;

            // Show view panel
            showPanel('view');
            document.querySelectorAll('.tab')[1].classList.add('active');
            document.querySelectorAll('.tab')[0].classList.remove('active');

            alert(currentLang === 'en' ?
                'Passport created successfully!' :
                '여권이 성공적으로 생성되었습니다!');
        }

        function addVaccination() {
            const type = document.getElementById('vaccineType').value;
            const date = document.getElementById('vaccineDate').value;
            const vet = document.getElementById('vetName').value;

            if (!date || !vet) {
                alert(currentLang === 'en' ?
                    'Please fill in all fields' :
                    '모든 필드를 입력해주세요');
                return;
            }

            const validUntil = new Date(date);
            validUntil.setFullYear(validUntil.getFullYear() + 1);

            const tbody = document.getElementById('vaccineTableBody');
            const row = document.createElement('tr');
            row.innerHTML = `
                <td>${type.charAt(0).toUpperCase() + type.slice(1)}</td>
                <td>${date}</td>
                <td>${vet}</td>
                <td>${validUntil.toISOString().split('T')[0]}</td>
                <td><span class="vacc-badge badge-valid">${currentLang === 'en' ? 'Valid' : '유효'}</span></td>
            `;
            tbody.appendChild(row);

            // Clear form
            document.getElementById('vaccineDate').value = '';
            document.getElementById('vetName').value = '';
        }

        function checkQuarantine() {
            const country = document.getElementById('destCountry').value;
            const result = document.getElementById('quarantineResult');
            result.style.display = 'block';

            // Simulate check (always pass for demo)
            result.className = 'quarantine-result quarantine-pass';
            document.getElementById('quarantineTitle').setAttribute('data-en', '[OK] Entry Permitted');
            document.getElementById('quarantineTitle').setAttribute('data-ko', '[OK] 입국 가능');
            setLang(currentLang);
        }

        function regenerateQR() {
            if (passportData) {
                alert(currentLang === 'en' ?
                    'QR code regenerated!' :
                    'QR 코드가 재생성되었습니다!');
            }
        }

        function downloadQR() {
            alert(currentLang === 'en' ?
                'QR code download started (demo)' :
                'QR 코드 다운로드 시작됨 (데모)');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            setLang('en');
        });
    </script>
</body>
</html>
