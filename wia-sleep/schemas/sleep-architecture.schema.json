{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wiastandards.com/schemas/sleep-architecture.schema.json",
  "title": "WIA-SLEEP Sleep Architecture",
  "description": "Detailed sleep structure and staging data schema",
  "type": "object",
  "properties": {
    "recordId": {
      "type": "string",
      "format": "uuid"
    },
    "subjectId": {
      "type": "string"
    },
    "recordingDate": {
      "type": "string",
      "format": "date"
    },
    "dataSource": {
      "type": "string",
      "enum": ["psg", "hsat", "consumer_wearable", "clinical_wearable", "actigraphy"],
      "description": "Source of sleep architecture data"
    },
    "scoringMethod": {
      "type": "string",
      "enum": ["AASM_2020", "AASM_2018", "AASM_2012", "R_and_K", "automated"],
      "description": "Sleep scoring methodology used"
    },
    "summary": {
      "type": "object",
      "properties": {
        "timeInBed_min": {
          "type": "number",
          "minimum": 0,
          "description": "Total time in bed"
        },
        "sleepPeriod_min": {
          "type": "number",
          "minimum": 0,
          "description": "Sleep period time (from sleep onset to final awakening)"
        },
        "totalSleepTime_min": {
          "type": "number",
          "minimum": 0,
          "description": "Total sleep time excluding wake periods"
        },
        "sleepEfficiency_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Sleep efficiency percentage"
        },
        "sleepOnsetLatency_min": {
          "type": "number",
          "minimum": 0,
          "description": "Latency to sleep onset"
        },
        "remLatency_min": {
          "type": "number",
          "minimum": 0,
          "description": "Latency to first REM period"
        },
        "wakeAfterSleepOnset_min": {
          "type": "number",
          "minimum": 0,
          "description": "Wake time after sleep onset"
        },
        "awakenings": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of awakenings"
        },
        "arousals_per_hour": {
          "type": "number",
          "minimum": 0,
          "description": "Arousal index"
        }
      },
      "required": ["totalSleepTime_min", "sleepEfficiency_pct"]
    },
    "stagePercentages": {
      "type": "object",
      "properties": {
        "wake_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "n1_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "N1 (NREM Stage 1) percentage"
        },
        "n2_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "N2 (NREM Stage 2) percentage"
        },
        "n3_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "N3 (Slow Wave Sleep) percentage"
        },
        "rem_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "REM sleep percentage"
        }
      }
    },
    "stageMinutes": {
      "type": "object",
      "properties": {
        "wake_min": { "type": "number", "minimum": 0 },
        "n1_min": { "type": "number", "minimum": 0 },
        "n2_min": { "type": "number", "minimum": 0 },
        "n3_min": { "type": "number", "minimum": 0 },
        "rem_min": { "type": "number", "minimum": 0 }
      }
    },
    "sleepCycles": {
      "type": "array",
      "description": "Individual sleep cycle details",
      "items": {
        "type": "object",
        "properties": {
          "cycleNumber": {
            "type": "integer",
            "minimum": 1
          },
          "startTime": {
            "type": "string",
            "format": "time"
          },
          "endTime": {
            "type": "string",
            "format": "time"
          },
          "duration_min": {
            "type": "number",
            "minimum": 0
          },
          "nremDuration_min": {
            "type": "number",
            "minimum": 0
          },
          "remDuration_min": {
            "type": "number",
            "minimum": 0
          },
          "n3Duration_min": {
            "type": "number",
            "minimum": 0,
            "description": "Deep sleep duration in this cycle"
          },
          "complete": {
            "type": "boolean",
            "description": "Whether this is a complete sleep cycle"
          }
        },
        "required": ["cycleNumber", "duration_min"]
      }
    },
    "hypnogram": {
      "type": "object",
      "description": "Epoch-by-epoch sleep staging data",
      "properties": {
        "epochDuration_sec": {
          "type": "integer",
          "enum": [30, 20],
          "description": "Duration of each epoch in seconds"
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "stages": {
          "type": "array",
          "description": "Array of sleep stages for each epoch (0=Wake, 1=N1, 2=N2, 3=N3, 5=REM)",
          "items": {
            "type": "integer",
            "enum": [0, 1, 2, 3, 5]
          }
        }
      }
    },
    "microstructure": {
      "type": "object",
      "description": "Sleep microstructure metrics",
      "properties": {
        "spindles": {
          "type": "object",
          "properties": {
            "density_per_min": { "type": "number", "minimum": 0 },
            "meanAmplitude_uV": { "type": "number" },
            "meanFrequency_Hz": { "type": "number" },
            "meanDuration_sec": { "type": "number" }
          }
        },
        "kComplexes": {
          "type": "object",
          "properties": {
            "density_per_min": { "type": "number", "minimum": 0 },
            "meanAmplitude_uV": { "type": "number" }
          }
        },
        "slowWaves": {
          "type": "object",
          "properties": {
            "density_per_min": { "type": "number", "minimum": 0 },
            "meanAmplitude_uV": { "type": "number" },
            "slowWaveActivity_uV2": { "type": "number", "description": "EEG power in 0.5-4 Hz band" }
          }
        },
        "remDensity_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "REM density (% of REM epochs with eye movements)"
        }
      }
    },
    "qualityMetrics": {
      "type": "object",
      "description": "Sleep quality assessment metrics",
      "properties": {
        "sleepQualityIndex": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Composite sleep quality score"
        },
        "restorationScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Physical restoration score based on SWS"
        },
        "cognitiveRecoveryScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Cognitive recovery score based on REM and sleep spindles"
        },
        "sleepFragmentation": {
          "type": "number",
          "minimum": 0,
          "description": "Sleep fragmentation index"
        }
      }
    }
  },
  "required": ["recordId", "subjectId", "recordingDate", "dataSource", "summary"]
}
