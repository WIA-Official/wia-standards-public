{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wiastandards.com/schemas/circadian-markers.schema.json",
  "title": "WIA-SLEEP Circadian Markers",
  "description": "Circadian rhythm biomarkers and phase indicators",
  "type": "object",
  "properties": {
    "recordId": {
      "type": "string",
      "format": "uuid"
    },
    "subjectId": {
      "type": "string"
    },
    "measurementDate": {
      "type": "string",
      "format": "date-time"
    },
    "melatonin": {
      "type": "object",
      "description": "Melatonin measurements and derived markers",
      "properties": {
        "dlmo": {
          "type": "object",
          "description": "Dim Light Melatonin Onset",
          "properties": {
            "time": {
              "type": "string",
              "format": "time"
            },
            "method": {
              "type": "string",
              "enum": ["saliva", "plasma", "urine_6SMT"]
            },
            "threshold_pg_ml": {
              "type": "number"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "dlmoff": {
          "type": "object",
          "description": "Dim Light Melatonin Offset",
          "properties": {
            "time": {
              "type": "string",
              "format": "time"
            }
          }
        },
        "melatoninDuration_hours": {
          "type": "number",
          "description": "Duration of elevated melatonin"
        },
        "peakLevel_pg_ml": {
          "type": "number",
          "description": "Peak melatonin level"
        },
        "peakTime": {
          "type": "string",
          "format": "time"
        },
        "measurements": {
          "type": "array",
          "description": "Time series of melatonin measurements",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "format": "time" },
              "level_pg_ml": { "type": "number" },
              "sampleType": { "type": "string", "enum": ["saliva", "plasma"] }
            }
          }
        }
      }
    },
    "cortisol": {
      "type": "object",
      "description": "Cortisol rhythm markers",
      "properties": {
        "awakeningResponse": {
          "type": "object",
          "description": "Cortisol Awakening Response (CAR)",
          "properties": {
            "wakeLevel_nmol_L": {
              "type": "number",
              "description": "Cortisol at awakening"
            },
            "peak30Level_nmol_L": {
              "type": "number",
              "description": "Cortisol 30 min after awakening"
            },
            "carMagnitude_nmol_L": {
              "type": "number",
              "description": "CAR magnitude (peak - wake)"
            },
            "carAuc_nmol_L_min": {
              "type": "number",
              "description": "Area under curve for CAR"
            }
          }
        },
        "diurnalSlope": {
          "type": "number",
          "description": "Diurnal cortisol slope (rate of decline)"
        },
        "nadirTime": {
          "type": "string",
          "format": "time",
          "description": "Time of cortisol nadir"
        },
        "nadirLevel_nmol_L": {
          "type": "number"
        }
      }
    },
    "coreBodyTemperature": {
      "type": "object",
      "description": "Core body temperature rhythm",
      "properties": {
        "nadir": {
          "type": "object",
          "properties": {
            "time": { "type": "string", "format": "time" },
            "temperature_C": { "type": "number" }
          }
        },
        "peak": {
          "type": "object",
          "properties": {
            "time": { "type": "string", "format": "time" },
            "temperature_C": { "type": "number" }
          }
        },
        "amplitude_C": {
          "type": "number",
          "description": "Temperature rhythm amplitude"
        },
        "measurements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "format": "date-time" },
              "temperature_C": { "type": "number" }
            }
          }
        }
      }
    },
    "heartRateVariability": {
      "type": "object",
      "description": "HRV-based circadian markers",
      "properties": {
        "nighttimeMetrics": {
          "type": "object",
          "properties": {
            "rmssd_ms": { "type": "number", "description": "RMSSD during sleep" },
            "sdnn_ms": { "type": "number", "description": "SDNN during sleep" },
            "lf_hf_ratio": { "type": "number", "description": "LF/HF ratio" },
            "hf_power_ms2": { "type": "number", "description": "High frequency power" }
          }
        },
        "circadianModulation": {
          "type": "object",
          "properties": {
            "amplitude": { "type": "number" },
            "acrophase": { "type": "string", "format": "time" },
            "mesor": { "type": "number" }
          }
        }
      }
    },
    "activityRhythm": {
      "type": "object",
      "description": "Rest-activity rhythm parameters",
      "properties": {
        "m10": {
          "type": "object",
          "description": "10 most active hours",
          "properties": {
            "onset": { "type": "string", "format": "time" },
            "activityLevel": { "type": "number" }
          }
        },
        "l5": {
          "type": "object",
          "description": "5 least active hours",
          "properties": {
            "onset": { "type": "string", "format": "time" },
            "activityLevel": { "type": "number" }
          }
        },
        "interdailyStability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Day-to-day consistency (0-1)"
        },
        "intradailyVariability": {
          "type": "number",
          "description": "Fragmentation of rhythm"
        },
        "relativeAmplitude": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Robustness of rhythm (0-1)"
        }
      }
    },
    "circadianPhase": {
      "type": "object",
      "description": "Computed circadian phase estimate",
      "properties": {
        "phaseAngle_hours": {
          "type": "number",
          "description": "Phase angle relative to external time"
        },
        "estimatedPhase_hours": {
          "type": "number",
          "minimum": 0,
          "maximum": 24,
          "description": "Current circadian phase (0-24 hours)"
        },
        "entrainmentStatus": {
          "type": "string",
          "enum": ["entrained", "free_running", "delayed", "advanced", "irregular"],
          "description": "Entrainment status"
        },
        "tau_hours": {
          "type": "number",
          "description": "Intrinsic period (tau)"
        },
        "phaseAngleToSleep": {
          "type": "number",
          "description": "Phase angle between DLMO and habitual sleep onset"
        }
      }
    }
  },
  "required": ["recordId", "subjectId", "measurementDate"]
}
