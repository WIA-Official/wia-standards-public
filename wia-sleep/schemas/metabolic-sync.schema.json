{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wiastandards.com/schemas/metabolic-sync.schema.json",
  "title": "WIA-SLEEP Metabolic Synchronization",
  "description": "Circadian-metabolic synchronization markers for sleep optimization",
  "type": "object",
  "properties": {
    "recordId": {
      "type": "string",
      "format": "uuid"
    },
    "subjectId": {
      "type": "string"
    },
    "measurementDate": {
      "type": "string",
      "format": "date"
    },
    "glucoseMetrics": {
      "type": "object",
      "description": "Glucose rhythm and variability",
      "properties": {
        "fastingGlucose_mg_dl": {
          "type": "number",
          "minimum": 0
        },
        "meanGlucose_mg_dl": {
          "type": "number",
          "minimum": 0
        },
        "glucoseVariability_cv_pct": {
          "type": "number",
          "description": "Coefficient of variation of glucose"
        },
        "timeInRange_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Time in target range (70-180 mg/dL)"
        },
        "nocturalGlucoseMean_mg_dl": {
          "type": "number",
          "description": "Mean glucose during sleep period"
        },
        "dawnPhenomenon": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "magnitude_mg_dl": { "type": "number" },
            "onsetTime": { "type": "string", "format": "time" }
          }
        },
        "glucoseRhythm": {
          "type": "object",
          "properties": {
            "amplitude_mg_dl": { "type": "number" },
            "acrophase": { "type": "string", "format": "time" },
            "nadir": { "type": "string", "format": "time" }
          }
        }
      }
    },
    "insulinMetrics": {
      "type": "object",
      "description": "Insulin sensitivity and rhythm",
      "properties": {
        "fastingInsulin_uU_ml": {
          "type": "number",
          "minimum": 0
        },
        "homaIr": {
          "type": "number",
          "description": "HOMA-IR insulin resistance index"
        },
        "matsudaIndex": {
          "type": "number",
          "description": "Matsuda insulin sensitivity index"
        },
        "insulinSensitivityCircadianVariation": {
          "type": "object",
          "properties": {
            "morningPeak": { "type": "number" },
            "eveningNadir": { "type": "number" },
            "amplitude": { "type": "number" }
          }
        }
      }
    },
    "appetiteHormones": {
      "type": "object",
      "description": "Hormones regulating appetite and energy balance",
      "properties": {
        "leptin": {
          "type": "object",
          "properties": {
            "fastingLevel_ng_ml": { "type": "number" },
            "peakTime": { "type": "string", "format": "time" },
            "nadirTime": { "type": "string", "format": "time" },
            "amplitude_ng_ml": { "type": "number" }
          }
        },
        "ghrelin": {
          "type": "object",
          "properties": {
            "fastingLevel_pg_ml": { "type": "number" },
            "peakTime": { "type": "string", "format": "time" },
            "preprandialSpike": { "type": "boolean" }
          }
        },
        "adiponectin_ug_ml": {
          "type": "number",
          "description": "Adiponectin level"
        },
        "glp1_pmol_L": {
          "type": "number",
          "description": "GLP-1 fasting level"
        }
      }
    },
    "mealTiming": {
      "type": "object",
      "description": "Meal timing relative to circadian rhythm",
      "properties": {
        "firstMealTime": {
          "type": "string",
          "format": "time"
        },
        "lastMealTime": {
          "type": "string",
          "format": "time"
        },
        "eatingWindow_hours": {
          "type": "number",
          "description": "Duration of eating window"
        },
        "mealTimingToCircadianPhase": {
          "type": "object",
          "properties": {
            "firstMealToDLMOff_hours": {
              "type": "number",
              "description": "Hours from melatonin offset to first meal"
            },
            "lastMealToDLMO_hours": {
              "type": "number",
              "description": "Hours from last meal to melatonin onset"
            }
          }
        },
        "chrononutritionScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Alignment of eating with circadian rhythm"
        }
      }
    },
    "energyExpenditure": {
      "type": "object",
      "description": "Energy expenditure rhythm",
      "properties": {
        "restingMetabolicRate_kcal_day": {
          "type": "number"
        },
        "dietInducedThermogenesis_pct": {
          "type": "number"
        },
        "thermorhythmAmplitude_pct": {
          "type": "number",
          "description": "Circadian variation in metabolic rate"
        },
        "fatOxidationRhythm": {
          "type": "object",
          "properties": {
            "peakTime": { "type": "string", "format": "time" },
            "nadirTime": { "type": "string", "format": "time" }
          }
        }
      }
    },
    "sleepMetabolicInteraction": {
      "type": "object",
      "description": "Interaction between sleep and metabolic function",
      "properties": {
        "sleepDebtMetabolicImpact": {
          "type": "object",
          "properties": {
            "accumulatedDebt_hours": { "type": "number" },
            "insulinSensitivityChange_pct": { "type": "number" },
            "leptinChange_pct": { "type": "number" },
            "ghrelinChange_pct": { "type": "number" }
          }
        },
        "glucoseToleranceByTime": {
          "type": "object",
          "properties": {
            "morningGTT": { "type": "number" },
            "eveningGTT": { "type": "number" },
            "ratio": { "type": "number" }
          }
        },
        "metabolicFlexibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Ability to switch between fuel sources"
        }
      }
    },
    "syncScore": {
      "type": "object",
      "description": "Overall circadian-metabolic synchronization assessment",
      "properties": {
        "overallScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Composite synchronization score"
        },
        "glucoseRhythmAlignment": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "mealTimingAlignment": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "hormonalRhythmIntegrity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string",
                "enum": ["meal_timing", "sleep_timing", "light_exposure", "exercise_timing"]
              },
              "recommendation": { "type": "string" },
              "priority": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              }
            }
          }
        }
      }
    }
  },
  "required": ["recordId", "subjectId", "measurementDate"]
}
