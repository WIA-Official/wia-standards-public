{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wiastandards.com/schemas/chronotype-assessment.schema.json",
  "title": "WIA-SLEEP Chronotype Assessment",
  "description": "Schema for chronotype assessment based on MCTQ and biological markers",
  "type": "object",
  "properties": {
    "assessmentId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this assessment"
    },
    "subjectId": {
      "type": "string",
      "description": "Subject identifier"
    },
    "assessmentDate": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time of assessment"
    },
    "mctqResponses": {
      "type": "object",
      "description": "Munich Chronotype Questionnaire responses",
      "properties": {
        "workdays": {
          "$ref": "#/definitions/sleepSchedule"
        },
        "freeDays": {
          "$ref": "#/definitions/sleepSchedule"
        },
        "workDaysPerWeek": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "alarmUsage": {
          "type": "boolean",
          "description": "Uses alarm clock on work days"
        },
        "alarmUsageFreeDays": {
          "type": "boolean",
          "description": "Uses alarm clock on free days"
        }
      },
      "required": ["workdays", "freeDays", "workDaysPerWeek"]
    },
    "actimetryData": {
      "type": "object",
      "description": "Actigraphy-based assessment data",
      "properties": {
        "recordingDays": {
          "type": "integer",
          "minimum": 7,
          "description": "Number of days of actigraphy recording"
        },
        "averageSleepOnset": {
          "type": "string",
          "format": "time"
        },
        "averageWakeTime": {
          "type": "string",
          "format": "time"
        },
        "sleepMidpoint": {
          "type": "string",
          "format": "time"
        },
        "interdailyStability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Interdaily stability index (0-1)"
        },
        "intradailyVariability": {
          "type": "number",
          "minimum": 0,
          "description": "Intradaily variability index"
        },
        "relativeAmplitude": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relative amplitude of rest-activity rhythm"
        }
      }
    },
    "biologicalMarkers": {
      "type": "object",
      "description": "Biological markers for chronotype",
      "properties": {
        "dlmo": {
          "type": "object",
          "properties": {
            "time": {
              "type": "string",
              "format": "time",
              "description": "Dim Light Melatonin Onset time"
            },
            "method": {
              "type": "string",
              "enum": ["saliva", "plasma", "urine_6SMT"],
              "description": "Measurement method"
            },
            "threshold_pg_ml": {
              "type": "number",
              "description": "Threshold used for DLMO determination"
            }
          }
        },
        "coreBodyTempNadir": {
          "type": "object",
          "properties": {
            "time": {
              "type": "string",
              "format": "time"
            },
            "temperature_C": {
              "type": "number"
            }
          }
        },
        "cortisolPeak": {
          "type": "object",
          "properties": {
            "time": {
              "type": "string",
              "format": "time"
            },
            "level_nmol_L": {
              "type": "number"
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "description": "Chronotype assessment result",
      "properties": {
        "msfsc": {
          "type": "number",
          "description": "MSFsc (corrected mid-sleep on free days)"
        },
        "chronotype": {
          "type": "string",
          "enum": ["extreme_early", "moderate_early", "intermediate", "moderate_late", "extreme_late"]
        },
        "socialJetlag_hours": {
          "type": "number",
          "description": "Social jetlag in hours"
        },
        "optimalSleepWindow": {
          "type": "object",
          "properties": {
            "bedtime": {
              "type": "string",
              "format": "time"
            },
            "wakeTime": {
              "type": "string",
              "format": "time"
            }
          }
        },
        "chronotypeScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Normalized chronotype score (0=extreme early, 100=extreme late)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence level of the assessment"
        }
      },
      "required": ["msfsc", "chronotype"]
    }
  },
  "required": ["assessmentId", "subjectId", "assessmentDate", "mctqResponses", "result"],
  "definitions": {
    "sleepSchedule": {
      "type": "object",
      "properties": {
        "bedtime": {
          "type": "string",
          "format": "time",
          "description": "Time of going to bed"
        },
        "sleepPrepTime_min": {
          "type": "number",
          "description": "Time spent in bed before attempting sleep"
        },
        "sleepLatency_min": {
          "type": "number",
          "description": "Time to fall asleep"
        },
        "wakeTime": {
          "type": "string",
          "format": "time",
          "description": "Time of waking up"
        },
        "getUpTime": {
          "type": "string",
          "format": "time",
          "description": "Time of getting out of bed"
        },
        "sleepDuration_hours": {
          "type": "number",
          "description": "Total sleep duration in hours"
        },
        "sleepInertia_min": {
          "type": "number",
          "description": "Duration of sleep inertia after waking"
        }
      },
      "required": ["bedtime", "wakeTime", "sleepDuration_hours"]
    }
  }
}
