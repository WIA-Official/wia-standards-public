{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wiastandards.com/schemas/wia-sleep-record.schema.json",
  "title": "WIA-SLEEP-Record",
  "description": "Comprehensive sleep data record for WIA-SLEEP standard supporting chronobiological personalization",
  "type": "object",
  "properties": {
    "recordId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this sleep record"
    },
    "subjectId": {
      "type": "string",
      "description": "Unique identifier for the subject/patient"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this record was created"
    },
    "chronotype": {
      "$ref": "#/definitions/chronotype"
    },
    "sleepArchitecture": {
      "$ref": "#/definitions/sleepArchitecture"
    },
    "circadianMarkers": {
      "$ref": "#/definitions/circadianMarkers"
    },
    "metabolicSync": {
      "$ref": "#/definitions/metabolicSync"
    },
    "environmentalFactors": {
      "$ref": "#/definitions/environmentalFactors"
    },
    "sleepDisorders": {
      "$ref": "#/definitions/sleepDisorders"
    },
    "interventions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/intervention"
      }
    },
    "geneticFactors": {
      "$ref": "#/definitions/geneticFactors"
    }
  },
  "required": ["recordId", "subjectId", "timestamp", "chronotype", "sleepArchitecture"],
  "definitions": {
    "chronotype": {
      "type": "object",
      "description": "Chronotype assessment based on MCTQ and biological markers",
      "properties": {
        "mctq_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 12,
          "description": "Munich Chronotype Questionnaire midpoint of sleep on free days (MSFsc)"
        },
        "classification": {
          "type": "string",
          "enum": ["extreme_early", "moderate_early", "intermediate", "moderate_late", "extreme_late"],
          "description": "Categorical chronotype classification"
        },
        "dim_light_melatonin_onset": {
          "type": "string",
          "format": "time",
          "description": "Dim Light Melatonin Onset (DLMO) time in HH:MM:SS format"
        },
        "core_body_temp_nadir": {
          "type": "string",
          "format": "time",
          "description": "Core body temperature minimum time"
        }
      },
      "required": ["mctq_score", "classification"]
    },
    "sleepArchitecture": {
      "type": "object",
      "description": "Sleep structure and staging metrics",
      "properties": {
        "totalSleepTime_min": {
          "type": "number",
          "minimum": 0,
          "description": "Total sleep time in minutes"
        },
        "sleepEfficiency_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Sleep efficiency percentage (TST/TIB * 100)"
        },
        "sleepOnsetLatency_min": {
          "type": "number",
          "minimum": 0,
          "description": "Time to fall asleep in minutes"
        },
        "wakeAfterSleepOnset_min": {
          "type": "number",
          "minimum": 0,
          "description": "Wake time after initial sleep onset in minutes"
        },
        "stages": {
          "type": "object",
          "properties": {
            "n1_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "N1 (light sleep) percentage"
            },
            "n2_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "N2 (intermediate sleep) percentage"
            },
            "n3_sws_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "N3/SWS (slow-wave/deep sleep) percentage"
            },
            "rem_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "REM sleep percentage"
            }
          }
        },
        "sleepCycles": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of complete sleep cycles"
        },
        "arousals_per_hour": {
          "type": "number",
          "minimum": 0,
          "description": "Arousal index (arousals per hour of sleep)"
        }
      },
      "required": ["totalSleepTime_min", "sleepEfficiency_pct"]
    },
    "circadianMarkers": {
      "type": "object",
      "description": "Circadian rhythm biomarkers",
      "properties": {
        "melatoninLevel_pg_ml": {
          "type": "number",
          "minimum": 0,
          "description": "Melatonin level in pg/mL"
        },
        "cortisolAwakeningResponse": {
          "type": "number",
          "description": "Cortisol awakening response (CAR) in nmol/L"
        },
        "coreBodyTemperature_C": {
          "type": "number",
          "description": "Core body temperature in Celsius"
        },
        "heartRateVariability": {
          "type": "object",
          "properties": {
            "rmssd": {
              "type": "number",
              "minimum": 0,
              "description": "Root Mean Square of Successive Differences in ms"
            },
            "lf_hf_ratio": {
              "type": "number",
              "minimum": 0,
              "description": "Low Frequency / High Frequency ratio"
            }
          }
        }
      }
    },
    "metabolicSync": {
      "type": "object",
      "description": "Metabolic synchronization markers for circadian-metabolic alignment",
      "properties": {
        "glucoseVariability_mg_dl": {
          "type": "number",
          "minimum": 0,
          "description": "Glucose variability (standard deviation) in mg/dL"
        },
        "insulinSensitivity_index": {
          "type": "number",
          "description": "Insulin sensitivity index"
        },
        "leptin_ng_ml": {
          "type": "number",
          "minimum": 0,
          "description": "Leptin level in ng/mL"
        },
        "ghrelin_pg_ml": {
          "type": "number",
          "minimum": 0,
          "description": "Ghrelin level in pg/mL"
        },
        "adiponectin_ug_ml": {
          "type": "number",
          "minimum": 0,
          "description": "Adiponectin level in ug/mL"
        }
      }
    },
    "environmentalFactors": {
      "type": "object",
      "description": "Environmental conditions affecting sleep",
      "properties": {
        "lightExposure": {
          "type": "object",
          "properties": {
            "morning_lux_hours": {
              "type": "number",
              "minimum": 0,
              "description": "Morning light exposure in lux-hours"
            },
            "evening_blue_light_min": {
              "type": "number",
              "minimum": 0,
              "description": "Evening blue light exposure duration in minutes"
            },
            "melanopic_edi": {
              "type": "number",
              "minimum": 0,
              "description": "Melanopic Equivalent Daylight Illuminance"
            }
          }
        },
        "temperature_C": {
          "type": "number",
          "description": "Room temperature in Celsius"
        },
        "humidity_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Room humidity percentage"
        },
        "noise_db": {
          "type": "number",
          "minimum": 0,
          "description": "Ambient noise level in decibels"
        },
        "altitude_m": {
          "type": "number",
          "description": "Altitude in meters"
        }
      }
    },
    "sleepDisorders": {
      "type": "object",
      "description": "Sleep disorder screening metrics",
      "properties": {
        "ahi_events_per_hour": {
          "type": "number",
          "minimum": 0,
          "description": "Apnea-Hypopnea Index (events per hour)"
        },
        "oxygenDesaturationIndex": {
          "type": "number",
          "minimum": 0,
          "description": "Oxygen Desaturation Index"
        },
        "plm_index": {
          "type": "number",
          "minimum": 0,
          "description": "Periodic Limb Movement Index"
        },
        "insomniaSeverityIndex": {
          "type": "integer",
          "minimum": 0,
          "maximum": 28,
          "description": "Insomnia Severity Index (ISI) score"
        },
        "epworthSleepinessScale": {
          "type": "integer",
          "minimum": 0,
          "maximum": 24,
          "description": "Epworth Sleepiness Scale (ESS) score"
        }
      }
    },
    "intervention": {
      "type": "object",
      "description": "Sleep intervention or treatment",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["light_therapy", "cbti", "chronotherapy", "pharmacological", "nutraceutical", "device"],
          "description": "Type of intervention"
        },
        "name": {
          "type": "string",
          "description": "Name of the specific intervention"
        },
        "timing": {
          "type": "string",
          "description": "Timing of intervention (e.g., '07:00', '2 hours before bed')"
        },
        "dosage": {
          "type": "string",
          "description": "Dosage or intensity of intervention"
        },
        "effectiveness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Effectiveness score from 0 to 1"
        }
      },
      "required": ["type", "name"]
    },
    "geneticFactors": {
      "type": "object",
      "description": "Genetic factors affecting sleep and circadian rhythm",
      "properties": {
        "clock_genes": {
          "type": "object",
          "properties": {
            "PER3_vntr": {
              "type": "string",
              "enum": ["4/4", "4/5", "5/5"],
              "description": "PER3 VNTR polymorphism"
            },
            "CLOCK_3111": {
              "type": "string",
              "enum": ["T/T", "T/C", "C/C"],
              "description": "CLOCK 3111T/C polymorphism"
            },
            "ADA_G22A": {
              "type": "string",
              "enum": ["G/G", "G/A", "A/A"],
              "description": "ADA G22A polymorphism"
            }
          }
        },
        "adenosine_sensitivity": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Adenosine sensitivity level (caffeine metabolism)"
        }
      }
    }
  }
}
