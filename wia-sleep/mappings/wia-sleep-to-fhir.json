{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WIA-SLEEP to FHIR R4 Mapping",
  "version": "1.0.0",
  "description": "Mapping between WIA-SLEEP standard and HL7 FHIR R4 resources",
  "mappings": {
    "SleepRecord": {
      "fhirResource": "Observation",
      "profile": "http://hl7.org/fhir/StructureDefinition/Observation",
      "fieldMappings": {
        "recordId": {
          "fhirPath": "Observation.identifier[0].value",
          "system": "urn:wia:sleep:record-id"
        },
        "subjectId": {
          "fhirPath": "Observation.subject.reference",
          "type": "Reference(Patient)"
        },
        "timestamp": {
          "fhirPath": "Observation.effectiveDateTime"
        },
        "sleepArchitecture.totalSleepTime_min": {
          "fhirPath": "Observation.component[code='total-sleep-time'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "93832-4",
            "display": "Sleep duration"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "min",
            "display": "minute"
          }
        },
        "sleepArchitecture.sleepEfficiency_pct": {
          "fhirPath": "Observation.component[code='sleep-efficiency'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "93831-6",
            "display": "Sleep efficiency"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "%",
            "display": "percent"
          }
        },
        "sleepArchitecture.sleepOnsetLatency_min": {
          "fhirPath": "Observation.component[code='sleep-latency'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "93833-2",
            "display": "Sleep latency"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "min",
            "display": "minute"
          }
        },
        "sleepArchitecture.stages.n3_sws_pct": {
          "fhirPath": "Observation.component[code='deep-sleep'].valueQuantity",
          "code": {
            "system": "http://wiastandards.com/fhir/CodeSystem/sleep-stages",
            "code": "n3-sws",
            "display": "N3 Slow Wave Sleep percentage"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "%",
            "display": "percent"
          }
        },
        "sleepArchitecture.stages.rem_pct": {
          "fhirPath": "Observation.component[code='rem-sleep'].valueQuantity",
          "code": {
            "system": "http://wiastandards.com/fhir/CodeSystem/sleep-stages",
            "code": "rem",
            "display": "REM sleep percentage"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "%",
            "display": "percent"
          }
        },
        "sleepArchitecture.arousals_per_hour": {
          "fhirPath": "Observation.component[code='arousal-index'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "93834-0",
            "display": "Arousal index"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "{events}/h",
            "display": "events per hour"
          }
        }
      },
      "category": [
        {
          "coding": [
            {
              "system": "http://terminology.hl7.org/CodeSystem/observation-category",
              "code": "vital-signs",
              "display": "Vital Signs"
            }
          ]
        }
      ],
      "code": {
        "coding": [
          {
            "system": "http://loinc.org",
            "code": "93830-8",
            "display": "Sleep study observation panel"
          },
          {
            "system": "http://wiastandards.com/fhir/CodeSystem/wia-sleep",
            "code": "sleep-record",
            "display": "WIA-SLEEP Record"
          }
        ]
      }
    },
    "ChronotypeProfile": {
      "fhirResource": "Observation",
      "profile": "http://hl7.org/fhir/StructureDefinition/Observation",
      "fieldMappings": {
        "mctqScore": {
          "fhirPath": "Observation.component[code='mctq-score'].valueQuantity",
          "code": {
            "system": "http://wiastandards.com/fhir/CodeSystem/wia-sleep",
            "code": "mctq-msfsc",
            "display": "MCTQ MSFsc Score"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "h",
            "display": "hour"
          }
        },
        "classification": {
          "fhirPath": "Observation.component[code='chronotype'].valueCodeableConcept",
          "code": {
            "system": "http://wiastandards.com/fhir/CodeSystem/wia-sleep",
            "code": "chronotype-class",
            "display": "Chronotype Classification"
          },
          "valueSet": "http://wiastandards.com/fhir/ValueSet/chronotype-classification"
        },
        "socialJetlag": {
          "fhirPath": "Observation.component[code='social-jetlag'].valueQuantity",
          "code": {
            "system": "http://wiastandards.com/fhir/CodeSystem/wia-sleep",
            "code": "social-jetlag",
            "display": "Social Jetlag"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "h",
            "display": "hour"
          }
        }
      },
      "code": {
        "coding": [
          {
            "system": "http://wiastandards.com/fhir/CodeSystem/wia-sleep",
            "code": "chronotype-assessment",
            "display": "Chronotype Assessment"
          }
        ]
      }
    },
    "SleepDisorderScreening": {
      "fhirResource": "Observation",
      "fieldMappings": {
        "ahi_events_per_hour": {
          "fhirPath": "Observation.component[code='ahi'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "69969-5",
            "display": "Apnea hypopnea index"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "{events}/h",
            "display": "events per hour"
          }
        },
        "insomniaSeverityIndex": {
          "fhirPath": "Observation.component[code='isi'].valueInteger",
          "code": {
            "system": "http://loinc.org",
            "code": "70274-6",
            "display": "Insomnia severity index score"
          }
        },
        "epworthSleepinessScale": {
          "fhirPath": "Observation.component[code='ess'].valueInteger",
          "code": {
            "system": "http://loinc.org",
            "code": "55754-0",
            "display": "Epworth sleepiness scale score"
          }
        }
      }
    },
    "CircadianMarkers": {
      "fhirResource": "Observation",
      "fieldMappings": {
        "melatonin.dlmo.time": {
          "fhirPath": "Observation.component[code='dlmo'].valueTime",
          "code": {
            "system": "http://wiastandards.com/fhir/CodeSystem/wia-sleep",
            "code": "dlmo",
            "display": "Dim Light Melatonin Onset"
          }
        },
        "cortisol.awakeningResponse.carMagnitude_nmol_L": {
          "fhirPath": "Observation.component[code='car'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "30500-5",
            "display": "Cortisol"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "nmol/L",
            "display": "nanomole per liter"
          }
        },
        "coreBodyTemperature.nadir.temperature_C": {
          "fhirPath": "Observation.component[code='cbt-nadir'].valueQuantity",
          "code": {
            "system": "http://loinc.org",
            "code": "8310-5",
            "display": "Body temperature"
          },
          "unit": {
            "system": "http://unitsofmeasure.org",
            "code": "Cel",
            "display": "degree Celsius"
          }
        }
      }
    }
  },
  "valueSets": {
    "chronotype-classification": {
      "url": "http://wiastandards.com/fhir/ValueSet/chronotype-classification",
      "name": "ChronotypeClassification",
      "concepts": [
        {"code": "extreme_early", "display": "Extreme Early Chronotype"},
        {"code": "moderate_early", "display": "Moderate Early Chronotype"},
        {"code": "intermediate", "display": "Intermediate Chronotype"},
        {"code": "moderate_late", "display": "Moderate Late Chronotype"},
        {"code": "extreme_late", "display": "Extreme Late Chronotype"}
      ]
    },
    "sleep-data-source": {
      "url": "http://wiastandards.com/fhir/ValueSet/sleep-data-source",
      "name": "SleepDataSource",
      "concepts": [
        {"code": "psg", "display": "Polysomnography"},
        {"code": "hsat", "display": "Home Sleep Apnea Test"},
        {"code": "consumer_wearable", "display": "Consumer Wearable"},
        {"code": "clinical_wearable", "display": "Clinical Wearable"},
        {"code": "actigraphy", "display": "Actigraphy"}
      ]
    }
  },
  "extensions": {
    "wia-sleep-chronotype": {
      "url": "http://wiastandards.com/fhir/StructureDefinition/wia-sleep-chronotype",
      "description": "Extension for chronotype information on Patient resource"
    },
    "wia-sleep-optimal-window": {
      "url": "http://wiastandards.com/fhir/StructureDefinition/wia-sleep-optimal-window",
      "description": "Extension for optimal sleep window timing"
    }
  }
}
