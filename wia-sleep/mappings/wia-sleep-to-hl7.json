{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WIA-SLEEP to HL7 v2.x Mapping",
  "version": "1.0.0",
  "description": "Mapping between WIA-SLEEP standard and HL7 v2.x messages",
  "messageTypes": {
    "ORU_R01": {
      "description": "Unsolicited observation message for sleep study results",
      "segments": {
        "MSH": {
          "description": "Message Header",
          "fields": {
            "MSH-9": "ORU^R01^ORU_R01",
            "MSH-21": "WIA-SLEEP-1.0"
          }
        },
        "PID": {
          "description": "Patient Identification",
          "mappings": {
            "subjectId": "PID-3 (Patient Identifier List)"
          }
        },
        "OBR": {
          "description": "Observation Request",
          "fields": {
            "OBR-4": {
              "wiaSleep": "Sleep study type",
              "mapping": {
                "psg": "93830-8^Sleep study observation panel^LN",
                "hsat": "93830-8^Sleep study observation panel^LN",
                "consumer_wearable": "WIA-SLP-CW^Consumer wearable sleep^WIA",
                "actigraphy": "WIA-SLP-ACT^Actigraphy^WIA"
              }
            }
          }
        },
        "OBX": {
          "description": "Observation segments for sleep data",
          "observations": [
            {
              "wiaSleepField": "sleepArchitecture.totalSleepTime_min",
              "OBX-3": "93832-4^Sleep duration^LN",
              "OBX-5": "{value}",
              "OBX-6": "min^minute^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.sleepEfficiency_pct",
              "OBX-3": "93831-6^Sleep efficiency^LN",
              "OBX-5": "{value}",
              "OBX-6": "%^percent^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.sleepOnsetLatency_min",
              "OBX-3": "93833-2^Sleep latency^LN",
              "OBX-5": "{value}",
              "OBX-6": "min^minute^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.wakeAfterSleepOnset_min",
              "OBX-3": "WIA-SLP-WASO^Wake after sleep onset^WIA",
              "OBX-5": "{value}",
              "OBX-6": "min^minute^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.stages.n1_pct",
              "OBX-3": "WIA-SLP-N1^N1 sleep percentage^WIA",
              "OBX-5": "{value}",
              "OBX-6": "%^percent^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.stages.n2_pct",
              "OBX-3": "WIA-SLP-N2^N2 sleep percentage^WIA",
              "OBX-5": "{value}",
              "OBX-6": "%^percent^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.stages.n3_sws_pct",
              "OBX-3": "WIA-SLP-N3^N3 SWS percentage^WIA",
              "OBX-5": "{value}",
              "OBX-6": "%^percent^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.stages.rem_pct",
              "OBX-3": "WIA-SLP-REM^REM sleep percentage^WIA",
              "OBX-5": "{value}",
              "OBX-6": "%^percent^UCUM"
            },
            {
              "wiaSleepField": "sleepArchitecture.arousals_per_hour",
              "OBX-3": "93834-0^Arousal index^LN",
              "OBX-5": "{value}",
              "OBX-6": "{events}/h^events per hour^UCUM"
            },
            {
              "wiaSleepField": "sleepDisorders.ahi_events_per_hour",
              "OBX-3": "69969-5^Apnea hypopnea index^LN",
              "OBX-5": "{value}",
              "OBX-6": "{events}/h^events per hour^UCUM"
            },
            {
              "wiaSleepField": "sleepDisorders.insomniaSeverityIndex",
              "OBX-3": "70274-6^Insomnia severity index score^LN",
              "OBX-5": "{value}",
              "OBX-6": "{score}^score^UCUM"
            },
            {
              "wiaSleepField": "sleepDisorders.epworthSleepinessScale",
              "OBX-3": "55754-0^Epworth sleepiness scale score^LN",
              "OBX-5": "{value}",
              "OBX-6": "{score}^score^UCUM"
            },
            {
              "wiaSleepField": "chronotype.mctq_score",
              "OBX-3": "WIA-SLP-MCTQ^MCTQ MSFsc score^WIA",
              "OBX-5": "{value}",
              "OBX-6": "h^hour^UCUM"
            },
            {
              "wiaSleepField": "chronotype.classification",
              "OBX-3": "WIA-SLP-CHRONO^Chronotype classification^WIA",
              "OBX-5": "{value}",
              "OBX-6": "^^^WIA-CHRONO"
            }
          ]
        }
      }
    }
  },
  "codeSystems": {
    "WIA": {
      "oid": "2.16.840.1.113883.6.xxx",
      "name": "WIA Standards Code System",
      "description": "Code system for WIA-SLEEP specific observations"
    }
  },
  "exampleMessage": "MSH|^~\\&|WIA-SLEEP|SENDER|RECEIVER|DEST|20250115120000||ORU^R01^ORU_R01|MSG001|P|2.5.1|||NE|AL||UNICODE UTF-8|||WIA-SLEEP-1.0\nPID|1||SUBJ-12345^^^WIA||DOE^JOHN||19850315|M\nOBR|1||ORD001|93830-8^Sleep study observation panel^LN|||20250114220000||||||||||||||20250115080000|||F\nOBX|1|NM|93832-4^Sleep duration^LN||432|min^minute^UCUM||N|||F\nOBX|2|NM|93831-6^Sleep efficiency^LN||89.5|%^percent^UCUM||N|||F\nOBX|3|NM|93833-2^Sleep latency^LN||12|min^minute^UCUM||N|||F\nOBX|4|NM|WIA-SLP-WASO^Wake after sleep onset^WIA||28|min^minute^UCUM||N|||F\nOBX|5|NM|WIA-SLP-N3^N3 SWS percentage^WIA||18.8|%^percent^UCUM||N|||F\nOBX|6|NM|WIA-SLP-REM^REM sleep percentage^WIA||24.3|%^percent^UCUM||N|||F\nOBX|7|NM|93834-0^Arousal index^LN||8.2|{events}/h^events per hour^UCUM||N|||F\nOBX|8|NM|WIA-SLP-MCTQ^MCTQ MSFsc score^WIA||4.5|h^hour^UCUM||N|||F\nOBX|9|CE|WIA-SLP-CHRONO^Chronotype classification^WIA||moderate_late^Moderate Late Chronotype^WIA-CHRONO||N|||F"
}
