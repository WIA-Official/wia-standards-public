{
  "name": "@wia/medical-ai-ethics",
  "version": "1.0.0",
  "description": "WIA Medical AI Ethics Standard - TypeScript SDK for ethical AI review in healthcare (弘益人間 - Benefit All Humanity)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wia",
    "medical-ai",
    "ethics",
    "healthcare",
    "standard",
    "ai-ethics",
    "medical-ethics",
    "bias-detection",
    "fairness",
    "transparency",
    "privacy",
    "hongik-ingan",
    "benefit-humanity"
  ],
  "author": {
    "name": "SmileStory Inc. / WIA",
    "email": "contact@wia.org",
    "url": "https://wia.org"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "medical-ai-ethics/api/typescript"
  },
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "homepage": "https://github.com/WIA-Official/wia-standards/tree/main/medical-ai-ethics",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "zod": "^3.22.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
