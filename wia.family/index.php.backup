<script>
    function chkMailFrm() {
        var f = document.formmail;
        if (!f.userName.value) {
            alert("Please enter your name");
            f.userName.focus();
            return false;
        }
        if (!f.email.value) {
            alert("Please enter your e-mail");
            f.email.focus();
            return false;
        }
        if (!f.phone.value) {
            alert("Please enter your phone");
            f.phone.focus();
            return false;
        }
        if (!f.content.value) {
            alert("Please enter your Message");
            f.content.focus();
            return false;
        }
    }

</script>

