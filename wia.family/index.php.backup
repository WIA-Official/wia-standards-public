        <script>
            document.addEventListener("DOMContentLoaded", function() {
                const imgBoxes = document.querySelectorAll(".img_box");
        
                imgBoxes.forEach(function(imgBox) {
                    const img = imgBox.querySelector("img");
                    const altText = imgBox.querySelector(".alt_text");
        
                    // 마우스가 올라가면 alt 텍스트 표시
                    imgBox.addEventListener("mouseenter", function() {
                        altText.textContent = img.alt;
                        altText.style.display = "block";
                    });
        
                    // 마우스가 나가면 alt 텍스트 숨김
                    imgBox.addEventListener("mouseleave", function() {
                        altText.style.display = "none";
                    });
                });
            });
        </script>
