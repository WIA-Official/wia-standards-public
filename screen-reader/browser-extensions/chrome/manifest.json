{
  "manifest_version": 3,
  "name": "WIA Screen Reader",
  "version": "1.0.0",
  "description": "Universal screen reader accessibility. WIHP pronunciation + WIA Braille for 211 languages. 弘益人間 - Benefit All Humanity",
  "author": "WIA Standards",
  "homepage_url": "https://wiastandards.com/screen-reader/",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "tts"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "WIA Screen Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "convert-wihp": {
      "suggested_key": {
        "default": "Alt+W"
      },
      "description": "Convert selection to WIHP"
    },
    "convert-braille": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Convert selection to Braille"
    },
    "speak-selection": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Speak selection"
    }
  }
}
