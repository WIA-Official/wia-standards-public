{
  "name": "@wia/fusion-sdk",
  "version": "1.0.0",
  "description": "WIA-FUSION SDK - Nuclear Fusion Energy Standard API Client",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wia",
    "fusion",
    "nuclear-fusion",
    "plasma",
    "tokamak",
    "iter",
    "kstar",
    "energy",
    "api",
    "sdk"
  ],
  "author": "WIA - World Certification Industry Association",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WIA-Official/wia-standards.git",
    "directory": "standards/WIA-FUSION/api/typescript"
  },
  "homepage": "https://wia.live/standards/fusion",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
