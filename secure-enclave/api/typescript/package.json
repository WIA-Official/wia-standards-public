{
  "name": "@wia/secure-enclave",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for WIA Secure Enclave - Hardware Security Module and Trusted Execution Environment",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wia",
    "secure-enclave",
    "hsm",
    "hardware-security-module",
    "tee",
    "trusted-execution-environment",
    "sgx",
    "trustzone",
    "cryptography",
    "key-management",
    "attestation",
    "secure-boot",
    "encryption",
    "digital-signature",
    "fips-140",
    "common-criteria",
    "security",
    "privacy",
    "compliance"
  ],
  "author": "WIA Technical Committee <tech@wia-standards.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wia-official/wia-standards.git",
    "directory": "secure-enclave/api/typescript"
  },
  "bugs": {
    "url": "https://github.com/wia-official/wia-standards/issues"
  },
  "homepage": "https://wia-standards.org/secure-enclave",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
