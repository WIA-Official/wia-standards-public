  },
  "homepage": "https://wiastandards.com/organ-shortage",
  "bugs": {
    "url": "https://github.com/WIA-Official/wia-standards/issues"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
