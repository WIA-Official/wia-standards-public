{
  "name": "@wia/organ-shortage-sdk",
  "version": "1.0.0",
  "description": "WIA-ORGAN-SHORTAGE Standard SDK - Unlimited Organ Supply Platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
