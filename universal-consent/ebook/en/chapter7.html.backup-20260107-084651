            <h2>Cloud Platform Integrations</h2>
            <h3>AWS Integration</h3>
            <div class="code-block">// Lambda function for consent verification
exports.handler = async (event) => {
  const consent = await wiaConsent.verify({
    userId: event.userId,
    purposeId: 'data-processing'
  });
  
  if (!consent.isValid) {
    return {
      statusCode: 403,
      body: JSON.stringify({
        error: 'Consent required for this operation'
      })
    };
  }
  
  // Proceed with data processing
};</div>
